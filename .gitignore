# ============================================================================
# Build Artifacts
# ============================================================================
build/
lib/sdl2/build/
*.o
*.a

# ============================================================================
# Dependencies
# ============================================================================
# Node.js
node_modules/
package-lock.json

# Python virtual environment
.venv/

# Python bytecode
__pycache__/
*.pyc
*.pyo

# ============================================================================
# Configuration
# ============================================================================
# Local config (user-specific, use config/helixconfig.json.template)
config/helixconfig.json
config/helixconfig-test.json
helixconfig.json

# Telemetry runtime state (generated by app, device-specific)
config/telemetry_*.json

# User-customized themes (track defaults/, ignore user overrides)
config/themes/*.json

# ============================================================================
# Generated Files & Logs
# ============================================================================
# NOTE: src/generated/ is tracked in git for cross-compilation support
# Regenerate with: make translations

# Auto-generated libhv logs
*.log
libhv.*.log

# Font generation timestamp
.fonts.stamp

# Render output artifacts
*.ppm

# ============================================================================
# Development Tools
# ============================================================================
# IDE/LSP
compile_commands.json
.cache/

.idea/
.vscode/

# Session notes (developer-specific)
SESSION_SUMMARY.md
IMPLEMENTATION_PLAN.md

# Claude plugin local config
.claude/*.local.md
.claude/worktrees/
.claude-recall/.gitignore

# OpenCode local state
.opencode/state/

# ============================================================================
# Platform-Specific
# ============================================================================
# macOS
.DS_Store
*.dSYM/

# Linux
*.swp
*.swo
*~

# ============================================================================
# Test Artifacts
# ============================================================================
# Unit test binaries
tests/unit/test_*
!tests/unit/test_*.cpp
!tests/unit/test_*.sh

# ============================================================================
# Asset Files (Large/Binary)
# ============================================================================
# G-Code sample files (binary, bloats repo history)
assets/gcode/*.gcode
assets/*.gcode

# ============================================================================
# Release Artifacts
# ============================================================================
# Local staging for release binaries (uploaded to GitHub Releases, not committed)
releases/
dist/
.worktrees/
# CJK source fonts (too large, download from GitHub notofonts/noto-cjk)
assets/fonts/NotoSansCJK*.otf
.bash-git-rc
config/helixconfig.json.voronv2

# ============================================================================
# Telemetry Analytics (local data pulled from R2)
# ============================================================================
.telemetry-data/
.env.telemetry
config/crash_report.txt
config/crash.txt
config/tool_spools.json
