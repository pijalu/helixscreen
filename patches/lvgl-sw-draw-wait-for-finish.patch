+#if LV_USE_OS
+/**
+ * Wait until all SW render threads finish their current task.
+ * Without this callback, lv_draw_dispatch() spins via self-signal and can
+ * free a draw task (cleanup_task → lv_free) while a render thread still
+ * holds a pointer to it — use-after-free crash in execute_drawing().
+ */
+static int32_t lv_draw_sw_wait_for_finish(lv_draw_unit_t * draw_unit)
+{
+    lv_draw_sw_unit_t * draw_sw_unit = (lv_draw_sw_unit_t *) draw_unit;
+
+    uint32_t i;
+    for(i = 0; i < LV_DRAW_SW_DRAW_UNIT_CNT; i++) {
+        /* Volatile cast: task_act is not declared volatile but is written by the
+         * render thread.  The cast ensures the compiler re-reads it each iteration
+         * and lv_sleep_ms provides a memory barrier on ARM64. */
+        while(*(volatile lv_draw_task_t * *)&draw_sw_unit->thread_dscs[i].task_act) {
+            lv_sleep_ms(1);
+        }
+    }
+
+    return 1;
+}
+#endif
