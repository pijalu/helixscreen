+/* Telemetry hook provided by helix_lvgl_anomaly.cpp — reports LVGL anomalies
+ * (double-schedule, UAF near-miss) via TelemetryManager::record_error. */
+extern void helix_lvgl_anomaly(const char * code, const char * context);
+
 void lv_obj_delete_async(lv_obj_t * obj)
 {
     LV_ASSERT_OBJ(obj, MY_CLASS);
+    /* Dedup: cancel any previously-scheduled async delete for this obj to
+     * prevent double-execution of lv_obj_delete_async_cb. The second
+     * callback would run after the first freed the object, producing a
+     * use-after-free crash inside lv_event_mark_deleted / obj_delete_core.
+     * Log + phone home on the first duplicate so we can correlate with
+     * device/panel context and track where the double-schedule comes from. */
+    lv_result_t cancel_res = lv_async_call_cancel(lv_obj_delete_async_cb, obj);
+    if(cancel_res == LV_RESULT_OK) {
+        const char * cls_name = (obj->class_p && obj->class_p->name) ? obj->class_p->name : "?";
+        LV_LOG_WARN("lv_obj_delete_async: duplicate schedule for %p (class=%s)",
+                    (void *)obj, cls_name);
+        char ctx[96];
+        lv_snprintf(ctx, sizeof(ctx), "class=%s", cls_name);
+        helix_lvgl_anomaly("obj_delete_async_dup", ctx);
+        while(lv_async_call_cancel(lv_obj_delete_async_cb, obj) == LV_RESULT_OK) { }
+    }
     lv_async_call(lv_obj_delete_async_cb, obj);
 }
 
@@ -646,7 +666,17 @@ void lv_obj_dump_tree(lv_obj_t * start_obj)
 
 static void lv_obj_delete_async_cb(void * obj)
 {
-    LV_ASSERT_OBJ(obj, MY_CLASS);
+    /* Guard against use-after-free: another code path may have already freed
+     * this object (e.g., parent's obj_delete_core recursed into children
+     * before the child's pending async delete could be cancelled, or a
+     * duplicate schedule slipped through). lv_obj_is_valid walks the
+     * display's screen tree and does not dereference `obj`, so it's safe
+     * even if obj is a freed pointer. */
+    if(!lv_obj_is_valid(obj)) {
+        LV_LOG_WARN("lv_obj_delete_async_cb: skipping invalid obj %p", obj);
+        helix_lvgl_anomaly("obj_delete_async_cb_invalid", "");
+        return;
+    }
 
     lv_obj_delete(obj);
 }
