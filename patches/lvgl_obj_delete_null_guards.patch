diff --git a/src/core/lv_obj_tree.c b/src/core/lv_obj_tree.c
index 2dc7a024f..40dadc187 100644
--- a/src/core/lv_obj_tree.c
+++ b/src/core/lv_obj_tree.c
@@ -646,7 +646,12 @@ void lv_obj_dump_tree(lv_obj_t * start_obj)

 static void lv_obj_delete_async_cb(void * obj)
 {
-    LV_ASSERT_OBJ(obj, MY_CLASS);
+    /*Guard against use-after-free: if the object was already freed
+     *(e.g. parent deletion recursed into children before the child's
+     *pending async delete could be cancelled), skip the deletion.
+     *This prevents SIGBUS/SIGSEGV in lv_event_mark_deleted when
+     *iterating the event list of a freed object.*/
+    if(!lv_obj_is_valid(obj)) return;

     lv_obj_delete(obj);
 }
@@ -667,7 +672,7 @@ static void obj_indev_reset(lv_indev_t * indev, lv_obj_t * obj)

 static void obj_delete_core(lv_obj_t * obj)
 {
-    if(obj->is_deleting)
+    if(obj == NULL || obj->is_deleting)
         return;

     obj->is_deleting = true;
@@ -682,9 +687,24 @@ static void obj_delete_core(lv_obj_t * obj)
     /*Clean registered event_cb*/
     if(obj->spec_attr) lv_event_remove_all(&(obj->spec_attr->event_list));

-    /*Recursively delete the children*/
+    /*Cancel any pending async deletions for this object first, before
+     *recursing into children. This prevents double-free when both parent
+     *and child have pending lv_obj_delete_async calls: without this,
+     *the parent's recursion frees the child, then the child's pending
+     *async fires on already-freed memory (SIGSEGV in lv_event_mark_deleted).*/
+    lv_result_t async_cancel_res = LV_RESULT_OK;
+    while(async_cancel_res == LV_RESULT_OK) {
+        async_cancel_res = lv_async_call_cancel(lv_obj_delete_async_cb, obj);
+    }
+
+    /*Recursively delete the children, cancelling any pending async
+     *deletions for each child before recursing to prevent use-after-free.*/
     lv_obj_t * child = lv_obj_get_child(obj, 0);
     while(child) {
+        lv_result_t child_cancel_res = LV_RESULT_OK;
+        while(child_cancel_res == LV_RESULT_OK) {
+            child_cancel_res = lv_async_call_cancel(lv_obj_delete_async_cb, child);
+        }
         obj_delete_core(child);
         child = lv_obj_get_child(obj, 0);
     }
@@ -713,12 +733,6 @@ static void obj_delete_core(lv_obj_t * obj)
         indev = lv_indev_get_next(indev);
     }

-    /*Delete all pending async del-s*/
-    lv_result_t async_cancel_res = LV_RESULT_OK;
-    while(async_cancel_res == LV_RESULT_OK) {
-        async_cancel_res = lv_async_call_cancel(lv_obj_delete_async_cb, obj);
-    }
-
     /*All children deleted. Now clean up the object specific data*/
     lv_obj_destruct(obj);

diff --git a/src/misc/lv_event.c b/src/misc/lv_event.c
index 39c17ffd1..ebe86e75b 100644
--- a/src/misc/lv_event.c
+++ b/src/misc/lv_event.c
@@ -317,9 +317,17 @@ uint32_t lv_event_register_id(void)

 void lv_event_mark_deleted(void * target)
 {
+    if(target == NULL) return;
+
     lv_event_t * e = event_head;

     while(e) {
+        /*Events are stack-allocated structs — always pointer-aligned.
+         *A misaligned pointer means the chain is corrupt (heap/stack
+         *corruption stomped event_head or a prev pointer). Bail out
+         *to avoid SIGSEGV from dereferencing garbage.*/
+        if((lv_uintptr_t)e & (sizeof(void *) - 1)) break;
+
         if(e->original_target == target || e->current_target == target) e->deleted = 1;
         e = e->prev;
     }
