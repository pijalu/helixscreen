@@ -317,12 +323,50 @@ uint32_t lv_event_register_id(void)
 
 void lv_event_mark_deleted(void * target)
 {
+    if(target == NULL) return;
+
     lv_event_t * e = event_head;
 
-    while(e) {
+    /*If no events are being dispatched (depth == 0), event_head MUST be
+     *NULL. A non-NULL value means something corrupted it — heap overflow,
+     *wild write, or a leaked push without pop. Reset and bail to prevent
+     *SIGSEGV from dereferencing garbage. Log the corruption for diagnosis.*/
+    if(e && event_depth == 0) {
+        LV_LOG_ERROR("event_head corruption: %p with depth=0 (target=%p), resetting", (void *)e, target);
+        char ctx[128];
+        lv_snprintf(ctx, sizeof(ctx), "event_head=%p target=%p depth=0", (void *)e, target);
+        helix_lvgl_anomaly("event_head_corruption", ctx);
+        event_head = NULL;
+        return;
+    }
+
+    /*Depth limit prevents infinite loops from corrupt circular chains.
+     *Event dispatch depth > 64 is abnormal (typical max is ~3-5 nested
+     *events). A corrupt prev pointer that happens to be aligned and
+     *mapped would be followed indefinitely without this.*/
+    int depth = 64;
+    while(e && depth-- > 0) {
+        /*Events are stack-allocated structs — always pointer-aligned.
+         *A misaligned pointer means the chain is corrupt (heap/stack
+         *corruption stomped event_head or a prev pointer). Bail out
+         *to avoid SIGSEGV from dereferencing garbage.*/
+        if((lv_uintptr_t)e & (sizeof(void *) - 1)) {
+            char ctx[128];
+            lv_snprintf(ctx, sizeof(ctx), "misaligned=%p target=%p depth=%d", (void *)e, target, 64 - depth);
+            helix_lvgl_anomaly("event_chain_corrupt", ctx);
+            break;
+        }
+
         if(e->original_target == target || e->current_target == target) e->deleted = 1;
         e = e->prev;
     }
+
+    /*Depth limit exhausted — likely a circular chain from corruption.*/
+    if(e && depth <= 0) {
+        char ctx[128];
+        lv_snprintf(ctx, sizeof(ctx), "depth_limit target=%p last_e=%p", target, (void *)e);
+        helix_lvgl_anomaly("event_chain_depth_limit", ctx);
+    }
 }
 
