diff --git a/src/core/lv_obj.c b/src/core/lv_obj.c
index 3ba67b92f..a4b2addda 100644
--- a/src/core/lv_obj.c
+++ b/src/core/lv_obj.c
@@ -602,6 +602,7 @@ static void lv_obj_constructor(const lv_obj_class_t * class_p, lv_obj_t * obj)
 static void lv_obj_destructor(const lv_obj_class_t * class_p, lv_obj_t * obj)
 {
     LV_UNUSED(class_p);
+    if(obj == NULL) return;

