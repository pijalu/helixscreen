<component>
  <!-- QR Scanner Overlay: fullscreen camera viewfinder with QR detection -->
  <view name="qr_scanner_overlay"
        width="100%" height="100%"
        style_bg_color="0x000000" style_bg_opa="255"
        style_pad_all="0">

    <!-- Camera viewfinder area (fullscreen background) -->
    <lv_image name="viewfinder"
              width="100%" height="100%"
              clickable="false" event_bubble="true"/>

    <!-- Targeting rectangle overlay (centered) -->
    <lv_obj name="target_frame"
            width="240" height="240"
            align="center"
            style_bg_opa="0"
            style_border_width="3"
            style_border_color="#primary"
            style_radius="12"
            clickable="false">
    </lv_obj>

    <!-- Instruction text below viewfinder -->
    <text_body text="Center QR code in frame"
               translation_tag="Center QR code in frame"
               style_text_color="#FFFFFF" style_text_opa="180"
               style_text_align="center"
               align="center"
               y="140"
               clickable="false"/>

    <!-- Top bar with close button -->
    <lv_obj name="top_bar"
            width="100%" height="56"
            align="top_mid"
            style_bg_opa="180"
            style_bg_color="0x000000"
            style_pad_left="#space_md"
            style_pad_right="#space_md"
            style_border_width="0"
            flex_flow="row"
            flex_main_place="center"
            flex_cross_place="center">

      <text_heading text="Scan Spool QR Code" translation_tag="Scan Spool QR Code" style_text_color="#FFFFFF" style_text_align="center"/>

    </lv_obj>

    <!-- Floating close button (top-right, matches camera fullscreen style) -->
    <lv_obj name="close_btn"
            align="top_right" flag_floating="true"
            width="#button_height" height="#button_height"
            style_translate_x="-24" style_translate_y="16"
            style_bg_color="#card_bg" style_bg_opa="120"
            style_radius="#border_radius" style_border_width="0">
      <event_cb trigger="clicked" callback="on_qr_scanner_close"/>
      <icon src="close" size="lg" style_text_color="#text"
            align="center"
            clickable="false" event_bubble="true"/>
    </lv_obj>

    <!-- Status text at bottom -->
    <lv_obj name="status_bar"
            width="100%" height="48"
            align="bottom_mid"
            style_bg_opa="180"
            style_bg_color="0x000000"
            style_border_width="0"
            flex_flow="row"
            flex_main_place="center"
            flex_cross_place="center">

      <text_body name="status_text"
                 style_text_color="#FFFFFF"
                 bind_text="qr_scanner_status"/>
    </lv_obj>

    <!-- Success flash overlay (hidden by default, shown on scan success) -->
    <lv_obj name="success_flash"
            width="100%" height="100%"
            style_bg_color="0xFFFFFF"
            style_bg_opa="255"
            style_border_width="0"
            clickable="false">
      <bind_flag_if_eq subject="qr_scanner_success" flag="hidden" ref_value="0"/>
    </lv_obj>
  </view>
</component>
