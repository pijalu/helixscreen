<!-- Belt Tension Tuning Panel - Measure and compare belt path frequencies -->
<!-- States: 0=START, 1=PROGRESS, 2=RESULTS, 3=STROBE, 4=ERROR -->
<component>
  <view name="panel_belt_tension"
        extends="lv_obj" width="#overlay_panel_width" height="100%" align="right_mid" style_border_width="0"
        style_pad_all="0" style_bg_opa="255" style_bg_color="#card_bg" scrollable="false" flex_flow="column">
    <!-- Header Bar -->
    <header_bar name="overlay_header" title="Belt Tension" title_tag="Belt Tension"/>
    <!-- Content Area -->
    <lv_obj name="panel_content"
            width="100%" flex_grow="1" style_pad_all="#space_lg" style_pad_gap="#space_md" scrollable="true"
            flex_flow="column">
      <!-- Disable content when printer not connected -->
      <bind_state_if_not_eq subject="nav_buttons_enabled" state="disabled" ref_value="1"/>
      <!-- ============================================================ -->
      <!-- STATE 0: START - Hardware summary + start button -->
      <!-- ============================================================ -->
      <lv_obj name="state_start"
              width="100%" height="content" style_pad_all="0" flex_flow="column" style_pad_gap="#space_md"
              scrollable="false">
        <bind_flag_if_not_eq subject="belt_tension_state" flag="hidden" ref_value="0"/>
        <!-- Hardware summary card (with help button) -->
        <lv_obj width="100%"
                height="content" style_bg_color="#screen_bg" style_bg_opa="255" style_radius="#border_radius"
                style_pad_all="#space_lg" flex_flow="column" style_pad_gap="#space_sm" scrollable="false">
          <!-- Title row: icon + text + help button -->
          <lv_obj width="100%"
                  height="content" style_pad_all="0" flex_flow="row" style_flex_cross_place="center"
                  style_pad_gap="#space_sm" scrollable="false">
            <icon src="waveform" size="lg" variant="primary"/>
            <text_body text="Measure belt path frequencies" translation_tag="Measure belt path frequencies" flex_grow="1" style_text_color="#text_muted"/>
            <ui_button name="btn_help" width="36" height="36" variant="ghost" icon="help_circle">
              <event_cb trigger="clicked" callback="belt_tension_help_cb"/>
            </ui_button>
          </lv_obj>
          <!-- Kinematics row -->
          <lv_obj width="100%" height="content" style_pad_all="0" flex_flow="row"
                  style_flex_main_place="space_between" style_flex_cross_place="center" scrollable="false">
            <text_body text="Kinematics" translation_tag="Kinematics"/>
            <text_body bind_text="bt_hw_kinematics" style_text_color="#primary"/>
          </lv_obj>
          <!-- ADXL row -->
          <lv_obj width="100%" height="content" style_pad_all="0" flex_flow="row"
                  style_flex_main_place="space_between" style_flex_cross_place="center" scrollable="false">
            <text_body text="Accelerometer" translation_tag="Accelerometer"/>
            <text_body bind_text="bt_hw_adxl" style_text_color="#primary"/>
          </lv_obj>
          <!-- LED row -->
          <lv_obj width="100%" height="content" style_pad_all="0" flex_flow="row"
                  style_flex_main_place="space_between" style_flex_cross_place="center" scrollable="false">
            <text_body text="Strobe LED" translation_tag="Strobe LED"/>
            <text_body bind_text="bt_hw_led" style_text_color="#primary"/>
          </lv_obj>
          <!-- Target frequency row -->
          <lv_obj width="100%" height="content" style_pad_all="0" flex_flow="row"
                  style_flex_main_place="space_between" style_flex_cross_place="center" scrollable="false">
            <text_body text="Target Frequency" translation_tag="Target Frequency"/>
            <text_body bind_text="bt_target_freq" style_text_color="#primary"/>
          </lv_obj>
        </lv_obj>
        <!-- Start button -->
        <ui_button name="btn_start" width="100%" height="#button_height"
                   icon="waveform" text="Start Check" translation_tag="Start Check"
                   variant="primary">
          <event_cb trigger="clicked" callback="belt_tension_start_cb"/>
        </ui_button>
      </lv_obj>
      <!-- ============================================================ -->
      <!-- STATE 1: PROGRESS - Testing in progress -->
      <!-- ============================================================ -->
      <lv_obj name="state_progress"
              width="100%" height="content" style_pad_all="0" flex_flow="column" style_pad_gap="#space_md"
              scrollable="false">
        <bind_flag_if_not_eq subject="belt_tension_state" flag="hidden" ref_value="1"/>
        <!-- Progress card -->
        <lv_obj width="100%"
                height="content" style_bg_color="#screen_bg" style_bg_opa="255" style_radius="#border_radius"
                style_pad_all="#space_xl" flex_flow="column" style_pad_gap="#space_md"
                style_flex_main_place="center" style_flex_cross_place="center" scrollable="false">
          <!-- Spinner (shown when progress is 0) -->
          <spinner name="bt_spinner" size="lg"/>
          <!-- Progress label -->
          <text_heading bind_text="bt_progress_label" style_text_align="center"/>
          <!-- Progress bar -->
          <progress_bar bind_value="bt_progress"/>
        </lv_obj>
        <!-- Cancel button -->
        <ui_button name="btn_cancel" width="100%" height="#button_height"
                   icon="close" text="Cancel" translation_tag="Cancel"
                   variant="danger">
          <event_cb trigger="clicked" callback="belt_tension_cancel_cb"/>
        </ui_button>
      </lv_obj>
      <!-- ============================================================ -->
      <!-- STATE 2: RESULTS - Show measurements -->
      <!-- ============================================================ -->
      <lv_obj name="state_results"
              width="100%" height="content" style_pad_all="0" flex_flow="column" style_pad_gap="#space_md"
              scrollable="false">
        <bind_flag_if_not_eq subject="belt_tension_state" flag="hidden" ref_value="2"/>
        <!-- Result cards row -->
        <lv_obj width="100%" height="content" style_pad_all="0" flex_flow="row"
                style_pad_gap="#space_md" scrollable="false">
          <!-- Path A card -->
          <belt_result_card title="Path A" title_tag="Path A"
                            freq_subject="bt_result_a_freq" status_subject="bt_result_a_status"/>
          <!-- Path B card -->
          <belt_result_card title="Path B" title_tag="Path B"
                            freq_subject="bt_result_b_freq" status_subject="bt_result_b_status"/>
        </lv_obj>
        <!-- Comparison card -->
        <lv_obj width="100%"
                height="content" style_bg_color="#screen_bg" style_bg_opa="255" style_radius="#border_radius"
                style_pad_all="#space_lg" flex_flow="column" style_pad_gap="#space_sm" scrollable="false">
          <!-- Title row with help button -->
          <lv_obj width="100%"
                  height="content" style_pad_all="0" flex_flow="row" style_flex_cross_place="center"
                  style_pad_gap="#space_sm" scrollable="false">
            <text_body text="Comparison" translation_tag="Comparison" flex_grow="1" style_text_color="#text_muted"/>
            <ui_button width="36" height="36" variant="ghost" icon="help_circle">
              <event_cb trigger="clicked" callback="belt_tension_results_help_cb"/>
            </ui_button>
          </lv_obj>
          <!-- Delta -->
          <lv_obj width="100%" height="content" style_pad_all="0" flex_flow="row"
                  style_flex_main_place="space_between" style_flex_cross_place="center" scrollable="false">
            <text_body text="Frequency Delta" translation_tag="Frequency Delta"/>
            <text_body bind_text="bt_result_delta" style_text_color="#primary"/>
          </lv_obj>
          <!-- Similarity -->
          <lv_obj width="100%" height="content" style_pad_all="0" flex_flow="row"
                  style_flex_main_place="space_between" style_flex_cross_place="center" scrollable="false">
            <text_body text="Path Similarity" translation_tag="Path Similarity"/>
            <text_body bind_text="bt_result_similarity" style_text_color="#primary"/>
          </lv_obj>
        </lv_obj>
        <!-- Recommendation card -->
        <lv_obj width="100%"
                height="content" style_bg_color="#screen_bg" style_bg_opa="255" style_radius="#border_radius"
                style_pad_all="#space_lg" flex_flow="column" style_pad_gap="#space_sm" scrollable="false">
          <icon src="info" size="md" variant="primary"/>
          <text_body width="100%" bind_text="bt_result_recommendation" long_mode="wrap"/>
        </lv_obj>
        <!-- Action buttons -->
        <ui_button name="btn_show_graph" width="100%" height="#button_height"
                   icon="waveform" text="Show Frequency Graph" translation_tag="Show Frequency Graph"
                   variant="secondary">
          <event_cb trigger="clicked" callback="belt_tension_show_graph_cb"/>
        </ui_button>
        <!-- Strobe fine-tuning (available with PWM LED or phone app) -->
        <ui_button name="btn_strobe" width="100%" height="#button_height"
                   icon="sine_wave" text="Visual Fine-Tune (Strobe)" translation_tag="Visual Fine-Tune (Strobe)"
                   variant="secondary">
          <event_cb trigger="clicked" callback="belt_tension_strobe_cb"/>
        </ui_button>
        <!-- Test Again button -->
        <ui_button name="btn_test_again" width="100%" height="#button_height"
                   icon="refresh" text="Test Again" translation_tag="Test Again"
                   variant="secondary">
          <event_cb trigger="clicked" callback="belt_tension_start_cb"/>
        </ui_button>
      </lv_obj>
      <!-- ============================================================ -->
      <!-- STATE 3: STROBE - Fine-tuning mode -->
      <!-- ============================================================ -->
      <lv_obj name="state_strobe"
              width="100%" height="content" style_pad_all="0" flex_flow="column" style_pad_gap="#space_md"
              scrollable="false">
        <bind_flag_if_not_eq subject="belt_tension_state" flag="hidden" ref_value="3"/>
        <!-- Strobe mode title row with help -->
        <lv_obj width="100%"
                height="content" style_bg_color="#screen_bg" style_bg_opa="255" style_radius="#border_radius"
                style_pad_all="#space_lg" flex_flow="row" style_flex_cross_place="center"
                style_pad_gap="#space_sm" scrollable="false">
          <icon src="sine_wave" size="lg" variant="primary"/>
          <text_body text="Adjust until belt appears frozen" translation_tag="Adjust until belt appears frozen" flex_grow="1" style_text_color="#text_muted"/>
          <ui_button width="36" height="36" variant="ghost" icon="help_circle">
            <event_cb trigger="clicked" callback="belt_tension_strobe_help_cb"/>
          </ui_button>
        </lv_obj>
        <!-- Strobe frequency display -->
        <lv_obj width="100%"
                height="content" style_bg_color="#screen_bg" style_bg_opa="255" style_radius="#border_radius"
                style_pad_all="#space_xl" flex_flow="column" style_pad_gap="#space_md"
                style_flex_main_place="center" style_flex_cross_place="center" scrollable="false">
          <text_small text="Current Frequency" translation_tag="Current Frequency" style_text_color="#text_muted"/>
          <text_heading bind_text="bt_strobe_freq" style_text_color="#primary"/>
          <!-- Adjustment buttons -->
          <lv_obj width="100%" height="content" style_pad_all="0" flex_flow="row"
                  style_pad_gap="#space_md" style_flex_main_place="center" scrollable="false">
            <ui_button width="30%" height="#button_height"
                       text="-0.5 Hz" variant="secondary">
              <event_cb trigger="clicked" callback="belt_tension_strobe_freq_down_cb"/>
            </ui_button>
            <ui_button width="30%" height="#button_height"
                       text="+0.5 Hz" variant="secondary">
              <event_cb trigger="clicked" callback="belt_tension_strobe_freq_up_cb"/>
            </ui_button>
          </lv_obj>
        </lv_obj>
        <!-- Dynamic instructions (changes based on hardware) -->
        <lv_obj width="100%"
                height="content" style_bg_color="#screen_bg" style_bg_opa="255" style_radius="#border_radius"
                style_pad_all="#space_lg" flex_flow="column" style_pad_gap="#space_sm" scrollable="false">
          <icon src="info" size="md" variant="primary"/>
          <text_body width="100%" bind_text="bt_strobe_instruction" long_mode="wrap"/>
        </lv_obj>
        <!-- Lock buttons -->
        <lv_obj width="100%" height="content" style_pad_all="0" flex_flow="row"
                style_pad_gap="#space_md" scrollable="false">
          <ui_button flex_grow="1" height="#button_height"
                     text="Lock A" translation_tag="Lock A" variant="secondary">
            <event_cb trigger="clicked" callback="belt_tension_lock_a_cb"/>
          </ui_button>
          <ui_button flex_grow="1" height="#button_height"
                     text="Lock B" translation_tag="Lock B" variant="secondary">
            <event_cb trigger="clicked" callback="belt_tension_lock_b_cb"/>
          </ui_button>
        </lv_obj>
        <!-- Back to results -->
        <ui_button name="btn_back_results" width="100%" height="#button_height"
                   icon="arrow_left" text="Back to Results" translation_tag="Back to Results"
                   variant="secondary">
          <event_cb trigger="clicked" callback="belt_tension_back_to_results_cb"/>
        </ui_button>
      </lv_obj>
      <!-- ============================================================ -->
      <!-- STATE 4: ERROR -->
      <!-- ============================================================ -->
      <lv_obj name="state_error"
              width="100%" height="content" style_pad_all="0" flex_flow="column" style_pad_gap="#space_md"
              scrollable="false">
        <bind_flag_if_not_eq subject="belt_tension_state" flag="hidden" ref_value="4"/>
        <!-- Error card -->
        <lv_obj width="100%"
                height="content" style_bg_color="#danger" style_bg_opa="25" style_radius="#border_radius"
                style_border_width="1" style_border_color="#danger"
                style_pad_all="#space_lg" flex_flow="column"
                style_flex_cross_place="center" style_pad_gap="#space_md" scrollable="false">
          <icon src="alert" size="lg" variant="danger"/>
          <text_heading text="Measurement Failed" translation_tag="Measurement Failed"
                        style_text_align="center" style_text_color="#danger"/>
          <text_body width="100%" bind_text="bt_error_message" long_mode="wrap" style_text_align="center"/>
        </lv_obj>
        <!-- Retry button -->
        <ui_button name="btn_retry" width="100%" height="#button_height"
                   icon="refresh" text="Retry" translation_tag="Retry"
                   variant="primary">
          <event_cb trigger="clicked" callback="belt_tension_retry_cb"/>
        </ui_button>
      </lv_obj>
    </lv_obj>
  </view>
</component>
