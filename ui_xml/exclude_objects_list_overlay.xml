<?xml version="1.0"?>
<component>
  <view name="exclude_objects_list_overlay"
        extends="overlay_panel" width="#keypad_width" title="Print Objects" title_tag="Print Objects">
    <lv_obj name="overlay_content"
            width="100%" flex_grow="1" style_pad_all="#space_md" scrollable="true" flex_flow="column"
            style_pad_gap="#space_sm">
      <!-- Rows populated dynamically by C++; hidden when no objects are defined -->
      <lv_obj name="objects_list" width="100%" height="content" flex_flow="column" style_pad_gap="#space_xs">
        <bind_flag_if_eq subject="defined_objects_count" flag="hidden" ref_value="0"/>
      </lv_obj>
      <!-- Empty state: shown when the print has no defined objects (slicer didn't label
           or Klipper's [exclude_object] module isn't configured). The "Objects" button
           upstream is usually gated, but this covers race/edge cases. -->
      <text_body name="objects_empty_state" text="No objects defined for this print"
                 translation_tag="No objects defined for this print" variant="muted"
                 style_text_align="center" width="100%"
                 style_pad_top="#space_md" style_pad_bottom="#space_md">
        <bind_flag_if_not_eq subject="defined_objects_count" flag="hidden" ref_value="0"/>
      </text_body>
    </lv_obj>
  </view>
</component>
