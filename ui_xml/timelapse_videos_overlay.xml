<!-- Timelapse Videos Overlay - Browse, render, and play timelapse recordings -->
<component>
  <view name="timelapse_videos_overlay"
        extends="overlay_panel" width="#overlay_panel_width_full" title="Timelapse Videos" title_tag="Timelapse Videos" bg_color="#screen_bg">
    <lv_obj name="overlay_content"
            width="100%" flex_grow="1" style_pad_top="0" style_pad_left="#space_lg" style_pad_right="#space_lg" style_pad_bottom="#space_lg" scrollable="true" flex_flow="column">
      <!-- ================================================================== -->
      <!-- RENDER CONTROLS -->
      <!-- ================================================================== -->
      <!-- Render section: hidden when 0 frames captured -->
      <lv_obj name="render_section"
              width="100%" height="content" scrollable="false" flex_flow="column"
              style_pad_top="#space_xs" style_pad_bottom="0">
        <bind_flag_if_eq subject="timelapse_frame_count" flag="hidden" ref_value="0"/>
        <!-- Frame count and capture info -->
        <lv_obj width="100%" height="content" scrollable="false" flex_flow="row"
                style_flex_cross_place="center" style_pad_gap="#space_sm"
                style_pad_bottom="#space_xs">
          <icon src="video" size="xs" variant="secondary"/>
          <text_small name="frame_count_label" bind_text="timelapse_frame_count" width="content"/>
          <text_small text=" frames" translation_tag=" frames" style_text_color="#text_muted"/>
          <text_small text=" · " style_text_color="#text_muted" width="content"/>
          <text_small name="capture_info_label" bind_text="timelapse_capture_info"
                      style_text_color="#text_muted" flex_grow="1" long_mode="dot"/>
        </lv_obj>
        <!-- Render progress bar with inline status - hidden when not rendering -->
        <lv_obj name="render_progress_container" width="100%" height="content" scrollable="false"
                flex_flow="column" style_pad_bottom="#space_xs">
          <bind_flag_if_eq subject="timelapse_render_progress" flag="hidden" ref_value="0"/>
          <lv_obj width="100%" height="content" scrollable="false" flex_flow="row"
                  style_flex_cross_place="center" style_pad_gap="#space_sm"
                  style_pad_bottom="#space_xs">
            <text_small name="render_status_text" bind_text="timelapse_render_status"
                        style_text_color="#text_muted" width="content"/>
            <progress_bar name="render_progress_bar" bind_value="timelapse_render_progress"
                          flex_grow="1"/>
          </lv_obj>
        </lv_obj>
        <!-- Render Now button -->
        <lv_button name="btn_render_now" width="100%" style_bg_color="#primary"
                   style_radius="#border_radius" style_pad_all="#space_sm">
          <event_cb trigger="clicked" callback="on_timelapse_render_now"/>
          <text_body text="Render Now" translation_tag="Render Now"
                     style_text_color="#on_primary" style_text_align="center" width="100%"
                     clickable="false" event_bubble="true"/>
        </lv_button>
      </lv_obj>
      <!-- ================================================================== -->
      <!-- VIDEO GRID -->
      <!-- ================================================================== -->
      <lv_obj name="video_grid_container"
              width="100%" flex_grow="1" scrollable="true" flex_flow="row_wrap"
              style_pad_top="#space_xs" style_pad_gap="#space_sm"
              style_flex_main_place="start"/>
      <!-- Empty state (centered icon + text, matching plugins/print files pattern) -->
      <!-- min_height ensures centering works inside scrollable parent (flex_grow can't) -->
      <lv_obj name="video_grid_empty"
              width="100%" style_min_height="380" scrollable="false" flex_flow="column"
              style_flex_main_place="center" style_flex_cross_place="center"
              style_flex_track_place="center" style_pad_gap="#space_md"
              hidden="true">
        <icon src="video_off" size="lg" variant="secondary"/>
        <text_body text="No timelapse videos found" translation_tag="No timelapse videos found"
                   style_text_color="#text_muted" style_text_align="center"/>
        <text_small text="Recorded timelapses will appear here" translation_tag="Recorded timelapses will appear here"
                    style_text_color="#text_muted" style_text_align="center"/>
      </lv_obj>
    </lv_obj>
  </view>
</component>
