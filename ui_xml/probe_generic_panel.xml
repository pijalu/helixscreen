<!-- Generic/Klicky fallback panel for probe overlay -->
<component>
  <view name="probe_generic_panel"
        extends="lv_obj" width="100%" height="content" style_pad_all="0"
        flex_flow="column" style_pad_gap="#space_sm" scrollable="false">

    <!-- Klicky dock controls (hidden unless Klicky type) -->
    <lv_obj name="klicky_controls" width="100%"
            height="content" style_pad_all="0" flex_flow="column"
            style_pad_gap="#space_sm" scrollable="false">
      <bind_flag_if_eq subject="probe_is_klicky" flag="hidden" ref_value="0"/>

      <setting_section_header title="KLICKY CONTROLS" title_tag="KLICKY CONTROLS" icon="magnet"/>

      <lv_obj width="100%" height="content" style_pad_all="0" flex_flow="row" flex_wrap="wrap"
              style_pad_gap="#space_sm" scrollable="false">
        <!-- Deploy (Attach) -->
        <ui_button name="btn_klicky_deploy"
                   width="48%" height="#button_height_sm" variant="secondary" text="Deploy" translation_tag="Deploy"
                   icon="arrow_down">
          <event_cb trigger="clicked" callback="on_klicky_deploy"/>
        </ui_button>

        <!-- Dock (Stow) -->
        <ui_button name="btn_klicky_dock"
                   width="48%" height="#button_height_sm" variant="secondary" text="Dock" translation_tag="Dock"
                   icon="arrow_up">
          <event_cb trigger="clicked" callback="on_klicky_dock"/>
        </ui_button>
      </lv_obj>
    </lv_obj>
  </view>
</component>
