<!-- Cartographer type-specific control panel for probe overlay -->
<component>
  <view name="probe_cartographer_panel"
        extends="lv_obj" width="100%" height="content" style_pad_all="0"
        flex_flow="column" style_pad_gap="#space_sm" scrollable="false">

    <setting_section_header title="CARTOGRAPHER" title_tag="CARTOGRAPHER" icon="sine_wave"/>

    <!-- Coil temperature readout -->
    <ui_card width="100%" height="content" style_border_width="0" style_pad_all="#space_md" scrollable="false"
             flex_flow="row" style_flex_cross_place="center" style_pad_gap="#space_md">
      <icon src="thermometer" size="sm" variant="secondary"/>
      <text_body text="Coil Temperature" translation_tag="Coil Temperature" flex_grow="1"/>
      <text_body bind_text="probe_carto_coil_temp" style_text_color="#text_accent"/>
    </ui_card>

    <!-- Action buttons -->
    <lv_obj width="100%"
            height="content" style_pad_all="0" flex_flow="row" flex_wrap="wrap" style_pad_gap="#space_sm"
            scrollable="false">

      <!-- Calibrate -->
      <ui_button name="btn_carto_calibrate"
                 width="48%" height="#button_height_sm" variant="secondary" text="Calibrate" translation_tag="Calibrate"
                 icon="target">
        <event_cb trigger="clicked" callback="on_carto_calibrate"/>
      </ui_button>

      <!-- Touch Calibrate -->
      <ui_button name="btn_carto_touch_cal"
                 width="48%" height="#button_height_sm" variant="secondary" text="Touch Cal" translation_tag="Touch Cal"
                 icon="tune">
        <event_cb trigger="clicked" callback="on_carto_touch_cal"/>
      </ui_button>
    </lv_obj>
  </view>
</component>
