<!-- Fan Settings Overlay -->
<!-- Shows all discovered fans grouped by controllable vs auto, with display names -->
<!-- XML-First Design: Layout/styling here; C++ populates fan lists dynamically -->
<component>
  <view name="fan_settings_overlay"
        extends="overlay_panel" width="#overlay_panel_width_full" title="Fans" title_tag="Fans"
        bg_color="#screen_bg">
    <!-- Content Area -->
    <lv_obj name="overlay_content"
            width="100%" flex_grow="1" style_pad_all="#space_md" style_pad_top="0" scrollable="true"
            scroll_elastic="false" flex_flow="column" style_pad_gap="#space_sm">

      <!-- ================================================================== -->
      <!-- CONTROLLABLE FANS SECTION (part cooling, fan_generic, output_pin) -->
      <!-- ================================================================== -->
      <lv_obj name="controllable_section"
              width="100%" height="content" style_bg_color="#screen_bg" style_bg_opa="255" style_radius="#border_radius"
              style_pad_all="0" scrollable="false" flex_flow="column" style_pad_gap="0">
        <setting_section_header title="CONTROLLABLE FANS" title_tag="Controllable Fans" icon="fan"
                                badge_name="controllable_fan_count" badge_text="0" hide_badge="false"/>
        <lv_obj name="controllable_fans_list"
                width="100%" height="content" style_pad_left="#space_lg" style_pad_right="#space_lg"
                style_pad_top="#space_sm" style_pad_bottom="#space_md" scrollable="false" flex_flow="column"
                style_pad_gap="0"/>
      </lv_obj>

      <!-- ================================================================== -->
      <!-- AUTO FANS SECTION (heater_fan, controller_fan, temperature_fan) -->
      <!-- ================================================================== -->
      <lv_obj name="auto_section"
              width="100%" height="content" style_bg_color="#screen_bg" style_bg_opa="255" style_radius="#border_radius"
              style_pad_all="0" scrollable="false" flex_flow="column" style_pad_gap="0">
        <setting_section_header title="AUTO FANS" title_tag="Auto Fans" icon="fan"
                                badge_name="auto_fan_count" badge_text="0" hide_badge="false"/>
        <lv_obj name="auto_fans_list"
                width="100%" height="content" style_pad_left="#space_lg" style_pad_right="#space_lg"
                style_pad_top="#space_sm" style_pad_bottom="#space_md" scrollable="false" flex_flow="column"
                style_pad_gap="0"/>
      </lv_obj>

      <!-- Empty state (no fans detected) -->
      <lv_obj name="no_fans_placeholder"
              width="100%" flex_grow="1" flex_flow="column"
              style_flex_main_place="center" style_flex_cross_place="center"
              style_bg_opa="0" style_border_width="0" scrollable="false" flag="hidden">
        <lv_image src="fan" style_opa="80"/>
        <text_body text="No fans detected" style_text_color="#text_secondary"/>
      </lv_obj>
    </lv_obj>
  </view>
</component>
