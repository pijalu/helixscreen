<component>
  <!-- Filament mapping pill: gcode-color dot → slot-color dot, with an
       optional tool-index label (Tx) centered over the gcode dot for
       multi-tool files. Colors, label text, label contrast color, and the
       empty-slot variant are set from C++; everything else (layout, sizes,
       fonts, padding) lives here so they can be tuned without rebuilding. -->
  <consts>
    <px name="pill_dot_sz" value="28"/>
  </consts>
  <view name="pill"
        extends="lv_obj" height="content"
        flex_flow="row" style_flex_main_place="center" style_flex_cross_place="center"
        style_pad_gap="#space_xs"
        style_pad_left="#space_sm" style_pad_right="#space_sm"
        style_pad_top="#space_sm" style_pad_bottom="#space_sm"
        style_radius="#space_lg"
        style_bg_color="#elevated_bg" style_bg_opa="255"
        style_border_width="0"
        scrollable="false" clickable="false" event_bubble="true">
    <!-- G-code color dot (hosts the Tx label on multi-tool files). -->
    <lv_obj name="gcode_dot"
            width="#pill_dot_sz" height="#pill_dot_sz"
            style_radius="9999" style_bg_opa="255"
            style_bg_color="#text_muted"
            style_border_width="1"
            style_border_color="#text_muted" style_border_opa="30"
            style_pad_all="0"
            scrollable="false" clickable="false" event_bubble="true">
      <lv_label name="tool_label"
                text="" align="center" hidden="true"
                style_text_font="#font_body"
                style_text_color="#text"
                clickable="false" event_bubble="true"/>
    </lv_obj>
    <!-- Arrow glyph. -->
    <lv_label name="arrow"
              text="#icon_arrow_right"
              style_text_font="#icon_font_sm"
              style_text_color="#text_muted"
              clickable="false" event_bubble="true"/>
    <!-- Mapped slot color dot. Border swaps to #warning when the slot is
         empty (set from C++). -->
    <lv_obj name="slot_dot"
            width="#pill_dot_sz" height="#pill_dot_sz"
            style_radius="9999" style_bg_opa="255"
            style_bg_color="#text_muted"
            style_border_width="1"
            style_border_color="#text_muted" style_border_opa="30"
            style_pad_all="0"
            scrollable="false" clickable="false" event_bubble="true"/>
  </view>
</component>
