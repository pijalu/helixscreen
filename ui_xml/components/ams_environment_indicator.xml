<component>
  <!--
    AMS Environment Indicator - Compact vertical display for temperature and humidity.

    Placed to the right of the spool grid inside ams_unit_detail.
    Two display modes:
    - Passive: thermometer icon + temp, water icon + humidity (stacked vertically)
    - Drying:  heat_wave icon + drying status text (stacked vertically)

    Hidden when no environment data exists. Clickable to open environment overlay.

    Subjects (per-unit indexed, currently unit 0):
    - ams_env_ind_0_temp_text: formatted temp ("24C")
    - ams_env_ind_0_humidity_text: formatted humidity ("46%")
    - ams_env_ind_0_humidity_status: 0=ok(green), 1=warn(yellow), 2=danger(red)
    - ams_env_ind_0_visible: 1 when environment data available
    - ams_env_ind_0_drying_active: 1 when drying in progress
    - ams_env_ind_0_drying_text: "47C > 55C  2:30"

    Callback:
    - on_env_indicator_clicked: opens environment overlay (not yet implemented)
  -->
  <view name="ams_environment_indicator" extends="lv_obj"
        width="content" height="content"
        style_margin_top="#space_xs"
        style_pad_top="#space_xs" style_pad_bottom="#space_xs"
        style_pad_left="#space_xxs" style_pad_right="#space_xxs"
        flex_flow="column" style_flex_main_place="center" style_flex_cross_place="center"
        style_pad_gap="#space_xxs" scrollable="false" clickable="true"
        style_bg_opa="140" style_bg_color="#screen_bg" style_radius="4"
        hidden="true">
    <bind_flag_if_eq subject="ams_env_ind_0_visible" flag="hidden" ref_value="0"/>
    <event_cb trigger="clicked" callback="on_env_indicator_clicked"/>

    <!-- Passive mode: temp + humidity stacked vertically -->
    <lv_obj width="content" height="content" style_pad_all="0"
            flex_flow="column" style_flex_main_place="center" style_flex_cross_place="center"
            style_pad_gap="#space_xxs" scrollable="false"
            clickable="false" event_bubble="true">
      <bind_flag_if_not_eq subject="ams_env_ind_0_drying_active" flag="hidden" ref_value="0"/>

      <!-- Temperature row -->
      <lv_obj width="content" height="content" style_pad_all="0"
              flex_flow="row" style_flex_main_place="center" style_flex_cross_place="center"
              style_pad_gap="#space_xxs" scrollable="false"
              clickable="false" event_bubble="true">
        <icon src="thermometer" size="sm" variant="secondary"
              clickable="false" event_bubble="true"/>
        <text_small bind_text="ams_env_ind_0_temp_text"
                    clickable="false" event_bubble="true"/>
      </lv_obj>

      <!-- Humidity row (color-coded by material comfort range) -->
      <lv_obj width="content" height="content" style_pad_all="0"
              flex_flow="row" style_flex_main_place="center" style_flex_cross_place="center"
              style_pad_gap="#space_xxs" scrollable="false"
              clickable="false" event_bubble="true">
        <icon src="water" size="sm" variant="secondary"
              clickable="false" event_bubble="true"/>
        <!-- OK (green/default) — visible when status=0 -->
        <text_small bind_text="ams_env_ind_0_humidity_text"
                    clickable="false" event_bubble="true" hidden="true">
          <bind_flag_if_not_eq subject="ams_env_ind_0_humidity_status" flag="hidden" ref_value="0"/>
        </text_small>
        <!-- Warning (yellow) — visible when status=1 -->
        <text_small bind_text="ams_env_ind_0_humidity_text" style_text_color="#warning"
                    clickable="false" event_bubble="true" hidden="true">
          <bind_flag_if_not_eq subject="ams_env_ind_0_humidity_status" flag="hidden" ref_value="1"/>
        </text_small>
        <!-- Danger (red) — visible when status=2 -->
        <text_small bind_text="ams_env_ind_0_humidity_text" style_text_color="#error"
                    clickable="false" event_bubble="true" hidden="true">
          <bind_flag_if_not_eq subject="ams_env_ind_0_humidity_status" flag="hidden" ref_value="2"/>
        </text_small>
      </lv_obj>
    </lv_obj>

    <!-- Drying mode: heat icon + status text stacked -->
    <lv_obj width="content" height="content" style_pad_all="0"
            flex_flow="column" style_flex_main_place="center" style_flex_cross_place="center"
            style_pad_gap="#space_xxs" scrollable="false"
            clickable="false" event_bubble="true">
      <bind_flag_if_eq subject="ams_env_ind_0_drying_active" flag="hidden" ref_value="0"/>
      <icon src="heat_wave" size="sm" variant="warning"
            clickable="false" event_bubble="true"/>
      <text_small bind_text="ams_env_ind_0_drying_text" style_text_color="#warning"
                  style_text_align="center"
                  clickable="false" event_bubble="true"/>
    </lv_obj>
  </view>
</component>
