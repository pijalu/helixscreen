<component>
  <styles>
    <!-- Applied to library_body per colspan; use two bind_styles because inline
         style_pad_gap would otherwise win over a single bind_style (CLAUDE.md rule #6). -->
    <style name="library_body_gap_default" pad_gap="#space_xs"/>
    <style name="library_body_gap_wide" pad_gap="#space_md"/>
  </styles>
  <view extends="ui_card" width="100%" height="100%">
    <bind_state_if_not_eq subject="printer_connection_state" state="disabled" ref_value="2"/>
    <event_cb trigger="clicked" callback="print_card_clicked_cb"/>
    <!-- IDLE STATE: Library card with thumbnail + file actions -->
    <!-- Visibility managed by C++ on_print_state_changed() + update_idle_compact_mode() -->
    <lv_obj name="print_card_idle"
            width="100%" height="100%" style_pad_all="0" flex_flow="column" style_pad_gap="0" clickable="false"
            event_bubble="true">
      <!-- Header: "Library" label with underline. Hidden flag bound to
           print_status_title_hidden (1 when show_title config is off OR at micro breakpoint). -->
      <lv_obj name="library_header"
              width="100%" height="content" flex_flow="column" style_pad_left="#space_sm" style_pad_right="#space_sm"
              style_pad_top="#space_xs" style_pad_bottom="0" style_pad_gap="#space_xxs" clickable="false"
              event_bubble="true">
        <bind_flag_if_eq subject="print_status_title_hidden" flag="hidden" ref_value="1"/>
        <text_small text="Print Library"
                    translation_tag="Print Library" text_transform="uppercase" variant="muted" clickable="false"
                    event_bubble="true"/>
        <divider_horizontal/>
      </lv_obj>
      <!-- Body: thumbnail left, action list right.
           pad_gap intentionally omitted inline — driven by bind_style per colspan. -->
      <lv_obj name="library_body"
              width="100%" flex_grow="1" style_pad_all="#space_xs" style_pad_left="0" flex_flow="row" scrollable="false"
              clickable="false" event_bubble="true">
        <bind_style name="library_body_gap_wide" subject="print_status_colspan" ref_value="3"/>
        <bind_style name="library_body_gap_default" subject="print_status_colspan" ref_value="2"/>
        <!-- Thumbnail (last print or benchy) -->
        <lv_image name="print_card_thumb"
                  width="40%" height="100%" src="A:assets/images/benchy_thumbnail_white.png" inner_align="contain"
                  clickable="false" event_bubble="true"/>
        <!-- Action list. Container hides when every row is hidden so the thumbnail
             can expand; C++ also adjusts width + flex alignment on that transition. -->
        <lv_obj name="library_actions"
                height="100%" flex_grow="1" flex_flow="column" style_pad_all="0" style_pad_top="#space_xxs"
                style_pad_bottom="#space_xxs" style_pad_gap="#space_sm" style_flex_main_place="space_evenly"
                scrollable="false" clickable="false" event_bubble="true">
          <bind_flag_if_eq subject="print_status_actions_hidden" flag="hidden" ref_value="1"/>
          <ui_button name="library_row_files" width="100%" height="#button_height_sm" variant="outline" layout="row">
            <bind_flag_if_eq subject="print_status_files_hidden" flag="hidden" ref_value="1"/>
            <icon src="folder" size="sm" clickable="false" event_bubble="true">
              <bind_flag_if_eq subject="print_status_column_mode" flag="hidden" ref_value="1"/>
            </icon>
            <text_small text="Print Files" translation_tag="Print Files" clickable="false" event_bubble="true"/>
            <event_cb trigger="clicked" callback="library_files_cb"/>
          </ui_button>
          <ui_button name="library_row_last" width="100%" height="#button_height_sm" variant="outline" layout="row">
            <bind_flag_if_eq subject="print_status_last_hidden" flag="hidden" ref_value="1"/>
            <icon src="clock" size="sm" clickable="false" event_bubble="true">
              <bind_flag_if_eq subject="print_status_column_mode" flag="hidden" ref_value="1"/>
            </icon>
            <text_small name="library_last_label"
                        text="Reprint Last" translation_tag="Reprint Last" clickable="false" event_bubble="true"/>
            <event_cb trigger="clicked" callback="library_last_cb"/>
          </ui_button>
          <ui_button name="library_row_recent" width="100%" height="#button_height_sm" variant="outline" layout="row">
            <bind_flag_if_eq subject="print_status_recent_hidden" flag="hidden" ref_value="1"/>
            <icon src="star" size="sm" clickable="false" event_bubble="true">
              <bind_flag_if_eq subject="print_status_column_mode" flag="hidden" ref_value="1"/>
            </icon>
            <text_small text="Recent Prints" translation_tag="Recent Prints" clickable="false" event_bubble="true"/>
            <event_cb trigger="clicked" callback="library_recent_cb"/>
          </ui_button>
          <ui_button name="library_row_queue"
                     width="100%" height="#button_height_sm" variant="outline" layout="row">
            <bind_flag_if_eq subject="print_status_queue_hidden" flag="hidden" ref_value="1"/>
            <icon src="progress_clock" size="sm" clickable="false" event_bubble="true">
              <bind_flag_if_eq subject="print_status_column_mode" flag="hidden" ref_value="1"/>
            </icon>
            <text_small name="library_queue_label"
                        text="Job Queue" translation_tag="Job Queue" clickable="false" event_bubble="true"/>
            <event_cb trigger="clicked" callback="library_queue_cb"/>
          </ui_button>
        </lv_obj>
      </lv_obj>
    </lv_obj>
    <!-- COMPACT IDLE STATE: Print Files + Print Last (for 1x2 size) -->
    <!-- No header, no thumbnail, no Recent — just the two most important actions -->
    <!-- Visibility managed by C++ update_idle_compact_mode(), not by subject binding -->
    <lv_obj name="print_card_idle_compact"
            width="100%" height="100%" style_pad_all="#space_xs" flex_flow="column" style_flex_main_place="center"
            style_pad_gap="#space_sm" hidden="true" clickable="false" event_bubble="true">
      <lv_image name="print_card_thumb_compact"
                width="100%" flex_grow="1" src="A:assets/images/benchy_thumbnail_white.png" inner_align="contain"
                clickable="false" event_bubble="true"/>
      <ui_button name="compact_row_files"
                 width="100%" height="#button_height_sm" variant="outline" text="Print Files"
                 translation_tag="Print Files">
        <bind_flag_if_eq subject="print_status_files_hidden" flag="hidden" ref_value="1"/>
        <event_cb trigger="clicked" callback="library_files_cb"/>
      </ui_button>
      <ui_button name="compact_row_last"
                 width="100%" height="#button_height_sm" variant="outline" text="Reprint Last"
                 translation_tag="Reprint Last">
        <bind_flag_if_eq subject="print_status_last_hidden" flag="hidden" ref_value="1"/>
        <event_cb trigger="clicked" callback="library_last_cb"/>
      </ui_button>
    </lv_obj>
    <!-- ACTIVE STATE: Shared container for preparing + printing phases -->
    <!-- Visibility managed by C++ on_print_state_changed(), not subject binding -->
    <lv_obj name="print_card_printing"
            width="100%" height="100%" style_pad_left="#space_sm" style_pad_right="#space_sm" style_pad_top="#space_xxs"
            style_pad_bottom="#space_sm" flex_flow="column" style_pad_gap="#space_xs" style_flex_cross_place="center"
            scrollable="false" hidden="true" clickable="false" event_bubble="true">
      <lv_obj name="print_card_layout"
              width="100%" flex_grow="1" style_pad_all="0" flex_flow="column" style_flex_cross_place="center"
              style_pad_gap="#space_sm" scrollable="false" clickable="false" event_bubble="true">
        <lv_obj name="print_card_thumb_wrap"
                width="100%" flex_grow="1" style_pad_all="0" style_bg_opa="0%" scrollable="false" clickable="false"
                event_bubble="true">
          <lv_image name="print_card_active_thumb"
                    width="100%" height="100%" src="A:assets/images/benchy_thumbnail_white.png" inner_align="contain"
                    clickable="false" event_bubble="true"/>
        </lv_obj>
        <!-- PREPARING info (visible when print_start_phase != 0) -->
        <lv_obj name="print_card_preparing_info"
                width="100%" style_pad_all="0" flex_flow="column" style_flex_main_place="center"
                style_flex_cross_place="center" style_pad_gap="#space_xs" scrollable="false" hidden="true"
                clickable="false" event_bubble="true">
          <bind_flag_if_eq subject="print_start_phase" flag="hidden" ref_value="0"/>
          <text_body text="Preparing Print" translation_tag="Preparing Print" clickable="false" event_bubble="true"/>
          <progress_bar name="print_start_bar"
                        width="90%" bind_value="print_start_progress" clickable="false" event_bubble="true"/>
          <text_small bind_text="print_start_message" clickable="false" event_bubble="true"/>
          <text_small name="print_start_eta"
                      bind_text="print_start_time_left" style_text_color="#text_muted" clickable="false"
                      event_bubble="true"/>
        </lv_obj>
        <!-- PRINTING info (visible when print_show_progress != 0) -->
        <lv_obj name="print_card_info"
                width="100%" style_pad_all="0" flex_flow="column" style_flex_main_place="center"
                style_flex_cross_place="center" style_pad_gap="#space_xs" scrollable="false" hidden="true"
                clickable="false" event_bubble="true">
          <bind_flag_if_eq subject="print_show_progress" flag="hidden" ref_value="0"/>
          <text_small width="100%"
                      bind_text="print_display_filename" style_text_color="#text" long_mode="wrap"
                      style_text_align="center" clickable="false" event_bubble="true"/>
          <progress_bar name="print_progress_bar"
                        width="90%" bind_value="print_progress" clickable="false" event_bubble="true"/>
          <text_small bind_text="print_progress_text" clickable="false" event_bubble="true"/>
        </lv_obj>
      </lv_obj>
      <text_small name="display_message"
                  width="100%" bind_text="display_message" variant="muted" style_text_align="center" long_mode="dots"
                  hidden="true" clickable="false" event_bubble="true">
        <bind_flag_if_eq subject="display_message_visible" flag="hidden" ref_value="0"/>
      </text_small>
    </lv_obj>
  </view>
</component>
