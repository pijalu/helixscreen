<component>
  <!-- Tray styling tokens - single source of truth for both AmsPanel and AmsOverviewPanel -->
  <consts>
    <color name="tray_bg" value="#505050"/>
    <color name="tray_border" value="#606060"/>
    <number name="tray_bg_opa" value="100"/>
    <px name="tray_default_height" value="30"/>
  </consts>
  <!--
    AMS Unit Detail - Shared spool grid + tray + labels layer structure.

    Used by both AmsPanel (single-unit view) and AmsOverviewPanel (detail mode).
    C++ resolves child widgets via lv_obj_find_by_name():
    - "slot_grid": flex row container for ams_slot widgets (created dynamically)
    - "labels_layer": overlay for material labels when 5+ slots overlap
    - "slot_tray": visual "holder" that renders ON TOP of spool bottoms

    Z-order (front to back): labels_layer > badge_layer > slot_tray > slot_grid > tray_back
    Badges reparented to badge_layer by ams_detail_update_badges() so they
    render in front of the tray.

    Layout: Row with slot_container (flex_grow) + optional environment indicator.
    When the indicator is visible, slot_container automatically narrows via flex.
    C++ reads available_width from lv_obj_get_parent(slot_grid) = slot_container,
    so slot sizing, overlap, labels, badges, and path canvas all adjust proportionally.
  -->
  <view name="ams_unit_detail" extends="lv_obj" width="100%" height="content"
        style_pad_all="0" style_pad_gap="0" flex_flow="row" scrollable="false">
    <!-- Slot container — holds grid, tray, labels, badges. Flex-grows to fill
         remaining width after indicator (if visible). Uses width="1" per L066
         so LVGL flex allocates based on grown width, not content width. -->
    <lv_obj name="slot_container" width="1" flex_grow="1" height="content"
            style_pad_all="0" scrollable="false">
      <!-- Slot Grid — back wall of 3D tray drawn via DRAW_MAIN callback on this object -->
      <lv_obj name="slot_grid"
              width="100%" height="content" style_pad_all="0" style_pad_row="0" style_pad_column="0" flex_flow="row"
              style_flex_main_place="start" style_flex_cross_place="start" scrollable="false">
        <!-- Slots created dynamically by ams_detail_create_slots() -->
      </lv_obj>
      <!-- Labels Layer - renders on top of overlapping slots for 5+ gates -->
      <lv_obj name="labels_layer" width="100%" height="80" style_pad_all="0" scrollable="false" clickable="false"/>
      <!-- Tray - visual "holder" in front of spools, positioned at bottom.
           Height set dynamically by ams_detail_update_tray() to 1/4 of slot height. -->
      <lv_obj name="slot_tray"
              width="100%" height="#tray_default_height" align="bottom_mid"
              style_bg_opa="0" style_border_width="0"
              style_pad_all="0" scrollable="false" clickable="false"/>
      <!-- Badge Layer - slot number badges reparented here to render in front of tray -->
      <lv_obj name="badge_layer" width="100%" height="100%" style_pad_all="0" scrollable="false" clickable="false"/>
    </lv_obj>
    <!-- Environment indicator (temp/humidity) — hidden when no sensors.
         Vertical column to the right of spools. When hidden, slot_container
         gets full width via flex_grow. -->
    <ams_environment_indicator name="env_indicator"/>
  </view>
</component>
