<component>
  <!-- Styles for reactive button selection (matches clog detection pattern) -->
  <styles>
    <style name="cam_btn_selected" bg_color="#primary" bg_opa="255"/>
    <style name="cam_btn_unselected" bg_color="#primary" bg_opa="40"/>
  </styles>

  <!-- Camera Configuration Modal
       Opened from grid edit mode gear icon on the camera widget.
       Rotation and flip settings. -->
  <view name="camera_config_modal"
        extends="ui_dialog" width="60%" height="content" align="center"
        flex_flow="column" style_flex_main_place="start" style_pad_gap="0">

    <!-- Header -->
    <modal_header icon_src="cog" icon_variant="accent" title="Camera" title_tag="Camera"/>

    <!-- Content -->
    <lv_obj width="100%" height="content"
            style_pad_left="#space_lg" style_pad_right="#space_lg"
            style_pad_top="#space_sm" style_pad_bottom="#space_lg"
            flex_flow="column" style_pad_gap="#space_md">

      <!-- Rotation row -->
      <lv_obj width="100%" height="content" flex_flow="column" style_pad_gap="#space_xs">
        <text_small text="Rotation" translation_tag="Rotation" style_text_color="#text_muted"/>
        <lv_obj width="100%" height="content" flex_flow="row" style_pad_gap="#space_xs">
          <ui_button name="btn_rot_0" text="0°" size="sm" flex_grow="1"
                     clickable="true">
            <bind_style name="cam_btn_selected" subject="cam_rot_0_active" ref_value="1"/>
            <bind_style name="cam_btn_unselected" subject="cam_rot_0_active" ref_value="0"/>
            <event_cb trigger="clicked" callback="on_cam_rotate_0"/>
          </ui_button>
          <ui_button name="btn_rot_90" text="90°" size="sm" flex_grow="1"
                     clickable="true">
            <bind_style name="cam_btn_selected" subject="cam_rot_90_active" ref_value="1"/>
            <bind_style name="cam_btn_unselected" subject="cam_rot_90_active" ref_value="0"/>
            <event_cb trigger="clicked" callback="on_cam_rotate_90"/>
          </ui_button>
          <ui_button name="btn_rot_180" text="180°" size="sm" flex_grow="1"
                     clickable="true">
            <bind_style name="cam_btn_selected" subject="cam_rot_180_active" ref_value="1"/>
            <bind_style name="cam_btn_unselected" subject="cam_rot_180_active" ref_value="0"/>
            <event_cb trigger="clicked" callback="on_cam_rotate_180"/>
          </ui_button>
          <ui_button name="btn_rot_270" text="270°" size="sm" flex_grow="1"
                     clickable="true">
            <bind_style name="cam_btn_selected" subject="cam_rot_270_active" ref_value="1"/>
            <bind_style name="cam_btn_unselected" subject="cam_rot_270_active" ref_value="0"/>
            <event_cb trigger="clicked" callback="on_cam_rotate_270"/>
          </ui_button>
        </lv_obj>
      </lv_obj>

      <!-- Flip row -->
      <lv_obj width="100%" height="content" flex_flow="column" style_pad_gap="#space_xs">
        <text_small text="Flip" translation_tag="Flip" style_text_color="#text_muted"/>
        <lv_obj width="100%" height="content" flex_flow="row" style_pad_gap="#space_xs">
          <ui_button name="btn_flip_h" text="Horizontal" translation_tag="Horizontal" size="sm" flex_grow="1"
                     clickable="true">
            <bind_style name="cam_btn_selected" subject="cam_flip_h_active" ref_value="1"/>
            <bind_style name="cam_btn_unselected" subject="cam_flip_h_active" ref_value="0"/>
            <event_cb trigger="clicked" callback="on_cam_flip_h_toggled"/>
          </ui_button>
          <ui_button name="btn_flip_v" text="Vertical" translation_tag="Vertical" size="sm" flex_grow="1"
                     clickable="true">
            <bind_style name="cam_btn_selected" subject="cam_flip_v_active" ref_value="1"/>
            <bind_style name="cam_btn_unselected" subject="cam_flip_v_active" ref_value="0"/>
            <event_cb trigger="clicked" callback="on_cam_flip_v_toggled"/>
          </ui_button>
        </lv_obj>
      </lv_obj>
    </lv_obj>

    <!-- Buttons -->
    <modal_button_row secondary_text="Cancel" secondary_callback="on_modal_cancel_clicked"
                      primary_text="Save" primary_callback="on_modal_ok_clicked"/>
  </view>
</component>
