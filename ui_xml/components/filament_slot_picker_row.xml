<component>
  <!-- One row in the filament slot picker popup: color swatch, slot label,
       optional material-mismatch warning. Colors, label text, warn
       visibility, and selected-state styling are set from C++. Sizes,
       padding, fonts, and radius live here so the row can be tuned without
       rebuilding. -->
  <view name="row"
        extends="lv_obj" width="100%" height="content"
        flex_flow="row" style_flex_cross_place="center"
        style_pad_all="#space_md" style_pad_gap="#space_md"
        style_radius="#space_sm"
        scrollable="false" clickable="true">
    <!-- Color swatch (filled for a mapped slot, warning-bordered transparent
         for an empty slot — handled by C++ post-config). -->
    <lv_obj name="swatch"
            width="#space_2xl" height="#space_2xl"
            style_radius="9999" style_bg_opa="255"
            style_bg_color="#text_muted"
            style_border_width="1"
            style_border_color="#text_muted" style_border_opa="30"
            style_pad_all="0"
            scrollable="false" clickable="false" event_bubble="true"/>
    <!-- Slot description ("Turtle 1 · Slot 2: PLA"). -->
    <lv_label name="slot_label"
              flex_grow="1" text="" long_mode="dots"
              style_text_font="#font_body" style_text_color="#text"
              clickable="false" event_bubble="true"/>
    <!-- Material-mismatch warning (shown only when the slot's material
         differs from the file's expected material). -->
    <lv_label name="warn_icon"
              hidden="true" text="#icon_triangle_exclamation"
              style_text_font="mdi_icons_16"
              style_text_color="#warning"
              clickable="false" event_bubble="true"/>
  </view>
</component>
