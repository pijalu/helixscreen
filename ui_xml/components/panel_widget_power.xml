<component>
  <view name="panel_widget_power" extends="lv_obj"
        height="100%" flex_grow="1" style_pad_all="0" scrollable="false">
    <ui_button name="power_button"
               width="100%" height="100%" variant="ghost" style_border_width="0" focusable="false">
      <!-- Hardware gate (power_device_count) checked in C++ populate_widgets() -->
      <bind_state_if_not_eq subject="moonraker_connection_state" state="disabled" ref_value="1"/>
      <icon name="power_icon" src="power_plug" size="#icon_size" align="center" variant="muted"/>
      <event_cb trigger="clicked" callback="power_toggle_cb"/>
    </ui_button>
    <text_tiny text="Power" translation_tag="Power"
               style_text_color="#text_muted" style_text_align="center"
               align="bottom_mid" y="-#space_md"
               clickable="false" event_bubble="true">
      <bind_flag_if_eq subject="show_widget_labels" flag="hidden" ref_value="0"/>
    </text_tiny>
  </view>
</component>
