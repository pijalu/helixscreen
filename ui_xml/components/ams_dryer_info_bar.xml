<component>
  <consts>
    <number name="bar_bg_opa" value="180"/>
  </consts>
  <!--
    AMS Dryer Info Bar - Compact temperature/humidity display above AMS visualization.

    Shows current temp, target temp (when drying), and humidity from dryer sensor.
    Tap to open dryer presets modal.
    Hidden when no dryer support and no humidity sensor.

    Subjects:
    - dryer_info_visible: controls visibility (1=show)
    - dryer_current_temp_text: current temp (e.g., "27C")
    - dryer_target_temp_text: target temp when drying (e.g., "55C")
    - dryer_humidity_text: humidity (e.g., "35%")
    - dryer_active: 1 when drying, 0 when idle
    - dryer_time_text: time remaining (e.g., "2:30 left")

    Callback:
    - dryer_open_modal_cb: opens dryer presets modal (registered by AmsDryerCard)

    C++ companion: AmsDryerCard (ui_ams_dryer_card.h) - resolves instance via "dryer_card" name
  -->
  <view name="ams_dryer_info_bar"
        extends="lv_obj" width="100%" height="content" style_pad_all="0" scrollable="false"
        hidden="true" flex_flow="row" style_flex_main_place="center">
    <!-- Hidden by default, shown when dryer or humidity sensor available -->
    <bind_flag_if_eq subject="dryer_info_visible" flag="hidden" ref_value="0"/>
    <!-- Clickable row - named "dryer_card" for AmsDryerCard instance resolution -->
    <lv_obj name="dryer_card"
            width="content" height="content" style_pad_left="#space_md" style_pad_right="#space_md"
            style_pad_top="#space_xs" style_pad_bottom="#space_xs"
            style_radius="#border_radius_small"
            style_bg_color="#elevated_bg" style_bg_opa="#bar_bg_opa"
            flex_flow="row" style_flex_main_place="center" style_flex_cross_place="center"
            style_pad_gap="#space_sm" scrollable="false" clickable="true">
      <event_cb trigger="clicked" callback="dryer_open_modal_cb"/>
      <!-- Temperature: thermometer icon + current temp -->
      <icon src="thermometer" size="sm" variant="secondary" clickable="false" event_bubble="true"/>
      <text_small bind_text="dryer_current_temp_text" clickable="false" event_bubble="true"/>
      <!-- Target temp separator (shown only when drying) -->
      <text_small text="/" clickable="false" event_bubble="true">
        <bind_flag_if_eq subject="dryer_active" flag="hidden" ref_value="0"/>
      </text_small>
      <text_small bind_text="dryer_target_temp_text" clickable="false" event_bubble="true">
        <bind_flag_if_eq subject="dryer_active" flag="hidden" ref_value="0"/>
      </text_small>
      <!-- Vertical divider between temp and humidity -->
      <divider_vertical clickable="false" event_bubble="true"/>
      <!-- Humidity: water drop icon + humidity -->
      <icon src="water" size="sm" variant="secondary" clickable="false" event_bubble="true"/>
      <text_small bind_text="dryer_humidity_text" clickable="false" event_bubble="true"/>
      <!-- Active drying indicator (hidden when not drying) -->
      <lv_obj height="content" style_pad_all="0" flex_flow="row"
              style_flex_cross_place="center" style_pad_gap="#space_xs"
              scrollable="false" clickable="false" event_bubble="true">
        <bind_flag_if_eq subject="dryer_active" flag="hidden" ref_value="0"/>
        <divider_vertical clickable="false" event_bubble="true"/>
        <icon src="heat_wave" size="sm" variant="warning" clickable="false" event_bubble="true"/>
        <text_small bind_text="dryer_time_text" style_text_color="#warning"
                    clickable="false" event_bubble="true"/>
      </lv_obj>
    </lv_obj>
  </view>
</component>
