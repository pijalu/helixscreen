<component>
  <view name="panel_widget_preheat" extends="lv_obj"
        height="100%" flex_grow="1" style_pad_all="0"
        style_pad_left="#space_xxs" style_pad_right="#space_xxs" scrollable="false"
        flex_flow="row" style_flex_main_place="space_between" style_flex_cross_place="center"
        style_pad_gap="#space_xs">
    <bind_state_if_not_eq subject="printer_connection_state" state="disabled" ref_value="2"/>

    <!-- Left: Preheat split button -->
    <ui_split_button name="preheat_split_btn"
                     width="1" flex_grow="1" height="#button_height"
                     variant="primary" icon="heat_wave"
                     text="Preheat PLA" options="PLA&#10;PETG&#10;ABS&#10;TPU"
                     selected="0" show_selection="false">
      <event_cb trigger="clicked" callback="preheat_widget_apply_cb"/>
      <event_cb trigger="value_changed" callback="preheat_widget_changed_cb"/>
    </ui_split_button>

    <!-- Tool target selector (visible only on multi-tool printers) -->
    <ui_button name="preheat_tool_target" variant="ghost"
               width="content" height="#button_height"
               style_pad_left="#space_sm" style_pad_right="#space_sm">
      <text_small name="tool_target_label" text="All"/>
      <event_cb trigger="clicked" callback="preheat_tool_target_cb"/>
    </ui_button>

    <!-- Right: Temp column (nozzle + bed) -->
    <lv_obj name="preheat_temp_column"
            width="content" height="100%" style_pad_all="0" scrollable="false"
            flex_flow="column" style_flex_main_place="center" style_flex_cross_place="center"
            style_pad_gap="#space_xxs">

      <!-- Nozzle row -->
      <lv_obj name="preheat_nozzle_row" width="content" height="content"
              style_pad_all="#space_xxs" scrollable="false" flex_flow="row"
              style_flex_main_place="center" style_flex_cross_place="center"
              style_pad_gap="#space_xxs" clickable="true">
        <event_cb trigger="clicked" callback="preheat_nozzle_tap_cb"/>
        <nozzle_icon name="preheat_nozzle_icon" size="xs" badge_subject=""
                     clickable="false" event_bubble="true"/>
        <temp_display size="xs" show_target="false" bind_current="extruder_temp"
                      bind_target="extruder_target"
                      clickable="false" event_bubble="true"/>
      </lv_obj>

      <!-- Bed row -->
      <lv_obj name="preheat_bed_row" width="content" height="content"
              style_pad_all="#space_xxs" scrollable="false" flex_flow="row"
              style_flex_main_place="center" style_flex_cross_place="center"
              style_pad_gap="#space_xxs" clickable="true">
        <event_cb trigger="clicked" callback="preheat_bed_tap_cb"/>
        <icon src="radiator" size="xs" variant="secondary"
              clickable="false" event_bubble="true"/>
        <temp_display size="xs" show_target="false" bind_current="bed_temp"
                      bind_target="bed_target"
                      clickable="false" event_bubble="true"/>
      </lv_obj>
    </lv_obj>
  </view>
</component>
