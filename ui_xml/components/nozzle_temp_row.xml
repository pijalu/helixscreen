<component name="nozzle_temp_row">
    <api>
        <prop name="tool_name" type="string" default="T0"/>
    </api>
    <view extends="lv_obj" name="nozzle_row_root"
          width="100%" height="content" flex_flow="column"
          style_pad_all="0" style_pad_row="0" style_pad_column="0"
          style_bg_opa="0" style_border_width="0" scrollable="false">
        <lv_obj width="100%" height="content" flex_flow="row"
                style_flex_main_place="space_between" style_flex_cross_place="center"
                style_pad_all="0" style_pad_row="0" style_pad_column="#space_sm"
                style_bg_opa="0" style_border_width="0"
                scrollable="false">
            <text_small name="tool_label" text="$tool_name" style_text_color="#primary"
                        width="content" style_min_width="#space_xl"/>
            <text_small name="temp_label" text="0°" flex_grow="1"/>
            <text_small name="target_label" text="off" style_text_color="#text_muted"
                        style_text_align="right"/>
        </lv_obj>
    </view>
</component>
