<component>
  <!-- Full-screen backdrop overlay - tap to dismiss -->
  <view name="favorite_macro_picker" extends="lv_obj"
        width="100%" height="100%" style_bg_opa="128" style_bg_color="0x000000"
        style_border_width="0" style_pad_all="0" style_radius="0" clickable="true">
    <event_cb trigger="clicked" callback="fav_macro_picker_backdrop_cb"/>
    <!-- Context menu card - width and position set dynamically by C++ -->
    <lv_obj name="context_menu"
            width="content" height="content" style_bg_color="#elevated_bg" style_bg_opa="255"
            style_radius="#border_radius" style_pad_all="#space_sm" style_pad_gap="#space_sm"
            flex_flow="row_wrap" style_flex_main_place="start" style_flex_cross_place="start"
            scrollable="false" clickable="true">

      <!-- Header row: spans full width, title + Done button -->
      <lv_obj width="100%" height="content"
              flex_flow="row" style_flex_main_place="space_between" style_flex_cross_place="center"
              style_pad_all="0"
              scrollable="false" clickable="false" event_bubble="true">
        <text_small text="Customize Macro" translation_tag="Customize Macro"
                    clickable="false" event_bubble="true"/>
        <ui_button name="btn_done" variant="ghost" width="content" height="content"
                   text="Done" translation_tag="Done" icon="check">
          <event_cb trigger="clicked" callback="fav_macro_picker_done_cb"/>
        </ui_button>
      </lv_obj>

      <!-- Horizontal divider — full width forces wrap -->
      <lv_obj width="100%" height="1" style_bg_color="#text_muted" style_bg_opa="38"
              style_pad_all="0" scrollable="false"
              clickable="false" event_bubble="true"/>

      <!-- Left column: macro list (constrained width, right column gets remaining) -->
      <lv_obj width="35%" height="content"
              flex_flow="column" style_pad_all="0" style_pad_gap="#space_xs"
              scrollable="false" style_min_width="100"
              clickable="false" event_bubble="true">
        <text_small text="Macro" translation_tag="Macro"
                   clickable="false" event_bubble="true"/>
        <lv_obj width="100%" height="1" style_bg_color="#text_muted" style_bg_opa="38"
                style_pad_all="0" scrollable="false"
                clickable="false" event_bubble="true"/>
        <!-- Macro rows populated dynamically by C++; max_height set dynamically -->
        <lv_obj name="macro_list" width="100%" height="content"
                flex_flow="column" style_pad_all="#space_xs" style_pad_gap="0"
                scrollable="true"/>
      </lv_obj>

      <!-- Vertical divider -->
      <lv_obj width="1" height="100%" style_bg_color="#text_muted" style_bg_opa="38"
              style_pad_all="0" scrollable="false"
              clickable="false" event_bubble="true"/>

      <!-- Right column: icon grid + color swatches (takes remaining width) -->
      <lv_obj name="right_column" width="1" height="content" flex_grow="1"
              flex_flow="column" style_pad_all="0" style_pad_gap="#space_xs"
              scrollable="false" style_min_width="160"
              clickable="false" event_bubble="true">
        <!-- Icon section -->
        <text_small text="Icon" translation_tag="Icon"
                   clickable="false" event_bubble="true"/>
        <lv_obj width="100%" height="1" style_bg_color="#text_muted" style_bg_opa="38"
                style_pad_all="0" scrollable="false"
                clickable="false" event_bubble="true"/>
        <!-- Icon grid: wrap row, max_height set dynamically by C++ -->
        <lv_obj name="icon_grid" width="100%" height="content"
                flex_flow="row_wrap" style_pad_all="#space_xs" style_pad_gap="#space_xs"
                scrollable="true"/>

        <!-- Color section -->
        <text_small text="Color" translation_tag="Color"
                   clickable="false" event_bubble="true"/>
        <lv_obj width="100%" height="1" style_bg_color="#text_muted" style_bg_opa="38"
                style_pad_all="0" scrollable="false"
                clickable="false" event_bubble="true"/>
        <!-- Color grid: wrap row, populated by C++ -->
        <lv_obj name="color_grid" width="100%" height="content"
                flex_flow="row_wrap" style_pad_all="#space_xs" style_pad_gap="#space_xs"
                scrollable="false"/>
      </lv_obj>
    </lv_obj>
  </view>
</component>
