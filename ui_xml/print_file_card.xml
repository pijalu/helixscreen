<component>
  <!-- Print File Card Component - Responsive Flexbox Layout
	     Uses flex_grow with min/max constraints to adapt to any screen size.
	     Container's flex_flow="row_wrap" will automatically fit cards and wrap.
	-->
  <api>
    <prop name="thumbnail_src" type="string"/>
    <prop name="filename" type="string"/>
    <prop name="print_time" type="string"/>
    <prop name="filament_weight" type="string"/>
  </api>
  <consts>
    <!-- Component-specific spacing (not in globals) -->
    <px name="metadata_top_pad" value="4"/>
    <px name="icon_text_gap" value="3"/>
    <!-- Card size constraints for responsive behavior -->
    <px name="card_base_width" value="170"/>
    <px name="card_min_width" value="140"/>
    <px name="card_max_width" value="230"/>
    <px name="card_height" value="245"/>
    <int name="metadata_overlay_opacity" value="160"/>
    <!-- Thumbnail height (overridden by C++ based on card width) -->
    <px name="thumbnail_height" value="150"/>
  </consts>
  <view name="card_root"
        extends="ui_card" height="#card_height" style_flex_basis="#card_base_width" flex_grow="1"
        style_min_width="#card_min_width" style_max_width="#card_max_width"
        style_pad_all="0" style_border_width="0" style_radius="#border_radius"
        clickable="true">
    <!-- Pre-rendered gradient background (LVGL native .bin for instant blitting)
         Source updated at runtime by C++ based on theme mode (dark/light) and card size -->
    <lv_image name="gradient_bg"
              width="100%" height="100%" inner_align="stretch"/>
    <!-- Thumbnail image - pre-scaled to exact display size via ThumbnailProcessor.
         Widget dimensions set by C++ to match .bin target (e.g. 160x160 for 800px),
         ensuring 1:1 blit with zero per-frame scaling overhead -->
    <lv_image name="thumbnail"
              src="$thumbnail_src" align="center"
              style_translate_y="#preview_offset_y"/>
    <!-- No-thumbnail placeholder - shown for files without real thumbnails -->
    <icon name="no_thumbnail_icon" src="cube_outline" size="xl" variant="tertiary"
          align="center" style_translate_y="-10" hidden="true"/>
    <!-- Folder icon - shown for regular directories (folder_type=1) -->
    <icon name="folder_icon" src="folder" size="xl" variant="warning"
          align="center" style_translate_y="-10" hidden="true"/>
    <!-- Parent directory icon - shown for ".." entries (folder_type=2) -->
    <icon name="parent_dir_icon" src="folder_arrow_up" size="xl" variant="warning"
          align="center" style_translate_y="-10" hidden="true"/>
    <!-- Metadata overlay - flat rectangle, flush to card bottom -->
    <lv_obj name="metadata_overlay"
            width="100%" height="content" align="bottom_mid"
            style_bg_color="#card_bg" style_bg_opa="#metadata_overlay_opacity" style_radius="0"
            style_pad_left="#space_xs" style_pad_right="#space_xs" style_pad_top="#space_lg"
            style_pad_bottom="#space_xs" style_border_width="0"
            flex_flow="column" scrollable="false">
      <!-- Filename label (single line, truncated with ...) -->
      <text_xs name="filename_label"
               width="100%" height="content" text="$filename" long_mode="dots" style_text_color="#text"/>
      <!-- Metadata row (horizontal layout, responsive) -->
      <!-- Hidden for directories via folder_type_subject binding in C++ -->
      <lv_obj name="metadata_row"
              width="100%" height="content" style_pad_all="0" style_pad_top="#metadata_top_pad" flex_flow="row"
              style_pad_gap="#space_xs">
        <!-- Print time (icon + text) -->
        <lv_obj height="100%"
                flex_grow="1" style_pad_all="0" flex_flow="row" style_pad_gap="#icon_text_gap"
                style_flex_cross_place="center">
          <icon src="clock" size="xs" variant="primary"/>
          <text_xs name="time_label" text="$print_time" flex_grow="1" style_translate_y="2"/>
        </lv_obj>
        <!-- Filament weight (icon + text) -->
        <lv_obj height="100%"
                flex_grow="1" style_pad_all="0" flex_flow="row" style_pad_gap="#icon_text_gap"
                style_flex_cross_place="center">
          <icon src="weight" size="xs" variant="primary"/>
          <text_xs name="filament_label" text="$filament_weight" flex_grow="1" style_translate_y="2"/>
        </lv_obj>
      </lv_obj>
    </lv_obj>
  </view>
</component>
