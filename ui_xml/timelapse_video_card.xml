<component>
  <!-- Timelapse Video Card Component
       Displays a thumbnail grid card for timelapse videos.
       Based on print_file_card.xml with video-specific metadata. -->
  <api>
    <prop name="thumbnail_src" type="string"/>
    <prop name="filename" type="string"/>
    <prop name="file_info" type="string"/>
  </api>
  <consts>
    <px name="metadata_top_pad" value="4"/>
    <px name="card_base_width" value="170"/>
    <px name="card_min_width" value="140"/>
    <px name="card_max_width" value="230"/>
    <px name="card_height" value="220"/>
    <int name="metadata_overlay_opacity" value="160"/>
    <px name="thumbnail_height" value="150"/>
    <px name="metadata_overlay_min_height" value="55"/>
    <px name="play_icon_size" value="40"/>
  </consts>
  <view name="card_root"
        extends="ui_card" height="#card_height" style_flex_basis="#card_base_width" flex_grow="1"
        style_min_width="#card_min_width" style_max_width="#card_max_width" style_pad_all="0" style_clip_corner="true"
        clickable="true">
    <!-- Pre-rendered gradient background -->
    <lv_image name="gradient_bg"
              width="#card_base_width" height="#card_height" src="A:assets/images/gradient-card-medium-dark.bin"
              inner_align="cover"/>
    <!-- Thumbnail image -->
    <lv_image name="thumbnail"
              width="100%" height="100%" src="$thumbnail_src" align="center" inner_align="contain"/>
    <!-- No-thumbnail placeholder -->
    <icon name="no_thumbnail_icon" src="video" size="xl" variant="tertiary"
          align="center" style_translate_y="-10" hidden="true"/>
    <!-- Play button overlay (centered, semi-transparent) -->
    <lv_obj name="play_overlay"
            width="#play_icon_size" height="#play_icon_size" align="center" style_translate_y="-10"
            style_bg_color="#000000" style_bg_opa="140" style_radius="20"
            scrollable="false" clickable="false" event_bubble="true">
      <icon src="play" size="sm" variant="on_primary" align="center" clickable="false" event_bubble="true"/>
    </lv_obj>
    <!-- Metadata clip container -->
    <lv_obj name="metadata_clip"
            width="100%" height="#metadata_overlay_min_height" style_radius="0" style_pad_all="0" align="bottom_mid"
            scrollable="false">
      <lv_obj name="metadata_overlay"
              width="100%" height="62" style_bg_opa="#metadata_overlay_opacity" style_radius="#border_radius"
              style_pad_left="#space_xs" style_pad_right="#space_xs" style_pad_top="#space_md"
              style_pad_bottom="#space_xs" align="bottom_mid" flex_flow="column" scrollable="false">
        <!-- Filename label -->
        <text_xs name="filename_label"
                 width="100%" height="18" text="$filename" long_mode="dots" style_text_color="#text"/>
        <!-- File info (size + date) -->
        <text_xs name="file_info_label"
                 width="100%" text="$file_info" style_text_color="#text_muted"
                 style_pad_top="#metadata_top_pad"/>
      </lv_obj>
    </lv_obj>
  </view>
</component>
