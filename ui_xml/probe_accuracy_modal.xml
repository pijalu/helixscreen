<?xml version="1.0"?>
<!-- SPDX-License-Identifier: GPL-3.0-or-later -->
<!-- Modal for PROBE_ACCURACY test: 3-state (PROBING, RESULTS, ERROR) -->
<component>
  <view name="probe_accuracy_modal"
        extends="ui_dialog" width="75%" height="content" style_min_width="320" style_max_width="440" align="center"
        flex_flow="column" style_flex_main_place="start" style_pad_gap="0">

    <!-- ============================================================ -->
    <!-- STATE: PROBING (state=1) - Progress bar + sample readout     -->
    <!-- ============================================================ -->
    <lv_obj name="probing_container"
            width="100%" height="content" style_min_height="160" style_pad_left="#space_lg" style_pad_right="#space_lg"
            style_pad_top="#space_lg" style_pad_bottom="#space_lg" flex_flow="column" style_flex_cross_place="center"
            style_flex_main_place="start" style_flex_track_place="center" style_pad_gap="#space_md" hidden="true">
      <bind_flag_if_not_eq subject="probe_acc_state" flag="hidden" ref_value="1"/>
      <!-- Title -->
      <text_heading width="100%"
                    text="Probe Accuracy Test" translation_tag="Probe Accuracy Test" style_text_align="center"/>
      <!-- Progress text: "Sample 3 of 10: z=1.2341" -->
      <text_muted name="probe_acc_progress_text"
                  width="100%" bind_text="probe_acc_progress_text" text="Preparing..." translation_tag="Preparing..."
                  style_text_align="center"/>
      <!-- Progress bar -->
      <progress_bar name="probe_acc_progress_bar" width="90%" bind_value="probe_acc_progress"/>
    </lv_obj>

    <!-- ============================================================ -->
    <!-- STATE: RESULTS (state=2) - Stats + individual samples        -->
    <!-- ============================================================ -->
    <lv_obj name="results_container"
            width="100%" height="content" style_pad_left="#space_lg" style_pad_right="#space_lg"
            style_pad_top="#space_lg" style_pad_bottom="#space_lg" flex_flow="column" style_flex_cross_place="center"
            style_pad_gap="#space_md" hidden="true">
      <bind_flag_if_not_eq subject="probe_acc_state" flag="hidden" ref_value="2"/>

      <!-- Quality icon: check for good (quality=1), warning for poor (quality=0) -->
      <icon src="check_circle" size="lg" variant="success" hidden="true">
        <bind_flag_if_not_eq subject="probe_acc_quality" flag="hidden" ref_value="1"/>
      </icon>
      <icon src="alert_triangle" size="lg" variant="warning" hidden="true">
        <bind_flag_if_not_eq subject="probe_acc_quality" flag="hidden" ref_value="0"/>
      </icon>

      <!-- Quality summary text -->
      <text_heading width="100%" bind_text="probe_acc_quality_text" style_text_align="center"/>

      <!-- Range (hero metric) -->
      <text_body width="100%" bind_text="probe_acc_range" style_text_align="center"/>

      <divider_horizontal/>

      <!-- Stats grid -->
      <lv_obj width="100%" height="content" flex_flow="column" style_pad_gap="#space_xs">

        <lv_obj width="100%" height="content" flex_flow="row" style_pad_gap="#space_sm">
          <text_small width="130" text="Maximum" translation_tag="Maximum" style_text_color="#text_muted"/>
          <text_small name="val_maximum" bind_text="probe_acc_maximum" flex_grow="1"/>
        </lv_obj>

        <lv_obj width="100%" height="content" flex_flow="row" style_pad_gap="#space_sm">
          <text_small width="130" text="Minimum" translation_tag="Minimum" style_text_color="#text_muted"/>
          <text_small name="val_minimum" bind_text="probe_acc_minimum" flex_grow="1"/>
        </lv_obj>

        <lv_obj width="100%" height="content" flex_flow="row" style_pad_gap="#space_sm">
          <text_small width="130" text="Average" translation_tag="Average" style_text_color="#text_muted"/>
          <text_small name="val_average" bind_text="probe_acc_average" flex_grow="1"/>
        </lv_obj>

        <lv_obj width="100%" height="content" flex_flow="row" style_pad_gap="#space_sm">
          <text_small width="130" text="Std Deviation" translation_tag="Std Deviation" style_text_color="#text_muted"/>
          <text_small name="val_stddev" bind_text="probe_acc_stddev" flex_grow="1"/>
        </lv_obj>
      </lv_obj>
    </lv_obj>

    <!-- ============================================================ -->
    <!-- STATE: ERROR (state=3) - Error message                       -->
    <!-- ============================================================ -->
    <lv_obj name="error_container"
            width="100%" height="content" style_min_height="160" style_pad_left="#space_lg" style_pad_right="#space_lg"
            style_pad_top="#space_lg" style_pad_bottom="#space_lg" flex_flow="column" style_flex_cross_place="center"
            style_flex_main_place="start" style_flex_track_place="center" style_pad_gap="#space_md" hidden="true">
      <bind_flag_if_not_eq subject="probe_acc_state" flag="hidden" ref_value="3"/>
      <icon src="alert_circle" size="lg" variant="danger"/>
      <text_heading width="100%"
                    text="Probe Accuracy Failed" translation_tag="Probe Accuracy Failed" style_text_align="center"/>
      <text_muted name="probe_acc_error_text"
                  width="100%" bind_text="probe_acc_error_msg" text="An error occurred."
                  translation_tag="An error occurred." long_mode="wrap" style_text_align="center"/>
    </lv_obj>

    <divider_horizontal/>

    <!-- ============================================================ -->
    <!-- Button row: PROBING state (state=1) - E-Stop                 -->
    <!-- ============================================================ -->
    <text_small width="100%"
                text="Stops all motion" translation_tag="Stops all motion" style_text_align="center"
                style_pad_top="#space_sm" style_pad_bottom="#space_sm" hidden="true">
      <bind_flag_if_not_eq subject="probe_acc_state" flag="hidden" ref_value="1"/>
    </text_small>
    <lv_obj name="probing_button_row"
            width="100%" height="#button_height" style_pad_all="0" style_pad_gap="0" flex_flow="row" hidden="true"
            scrollable="false">
      <bind_flag_if_not_eq subject="probe_acc_state" flag="hidden" ref_value="1"/>
      <ui_button name="btn_emergency_stop"
                 height="100%" flex_grow="1" style_radius="0" variant="danger" icon="alert_octagon"
                 text="EMERGENCY STOP" translation_tag="EMERGENCY STOP">
        <event_cb trigger="clicked" callback="on_probe_accuracy_estop"/>
      </ui_button>
    </lv_obj>

    <!-- ============================================================ -->
    <!-- Button row: RESULTS state (state=2) - OK                     -->
    <!-- ============================================================ -->
    <lv_obj name="results_button_row"
            width="100%" height="#button_height" style_pad_all="0" style_pad_gap="0" flex_flow="row" hidden="true"
            scrollable="false">
      <bind_flag_if_not_eq subject="probe_acc_state" flag="hidden" ref_value="2"/>
      <ui_button name="btn_ok" height="100%" flex_grow="1" style_radius="0" text="OK" translation_tag="OK">
        <event_cb trigger="clicked" callback="on_probe_accuracy_close"/>
      </ui_button>
    </lv_obj>

    <!-- ============================================================ -->
    <!-- Button row: ERROR state (state=3) - Close                    -->
    <!-- ============================================================ -->
    <lv_obj name="error_button_row"
            width="100%" height="#button_height" style_pad_all="0" style_pad_gap="0" flex_flow="row" hidden="true"
            scrollable="false">
      <bind_flag_if_not_eq subject="probe_acc_state" flag="hidden" ref_value="3"/>
      <ui_button name="btn_error_close"
                 height="100%" flex_grow="1" style_radius="0" text="Close" translation_tag="Close">
        <event_cb trigger="clicked" callback="on_probe_accuracy_close"/>
      </ui_button>
    </lv_obj>

  </view>
</component>
