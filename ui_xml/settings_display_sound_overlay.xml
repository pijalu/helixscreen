<!-- Display & Sound Settings Overlay Panel -->
<!-- Merges Appearance, Display, and Sound settings into a single sub-panel -->
<!-- Uses setting_* components for consistency with main settings panel -->
<component>
  <view name="settings_display_sound_overlay"
        extends="overlay_panel" width="#overlay_panel_width_full" title="Display &amp; Sound" title_tag="Display &amp; Sound"
        bg_color="#screen_bg">
    <!-- Content Area - no padding, rows handle their own -->
    <lv_obj name="overlay_content" width="100%" flex_grow="1" style_pad_top="0" style_pad_left="#space_lg" style_pad_right="#space_lg" style_pad_bottom="#space_lg" scrollable="true" flex_flow="column">
      <!-- ================================================================== -->
      <!-- APPEARANCE SECTION -->
      <!-- ================================================================== -->
      <setting_section_header title="APPEARANCE" title_tag="APPEARANCE" icon="light"/>
      <!-- Language Dropdown -->
      <setting_dropdown_row name="row_language"
                            label="Language" label_tag="Language" icon="translate" description="Choose display language"
                            description_tag="Choose display language" callback="on_language_changed"/>
      <!-- Timezone Dropdown (options populated dynamically in C++) -->
      <setting_dropdown_row name="row_timezone"
                            label="Timezone" label_tag="Timezone" icon="clock"
                            description="Set local timezone for time display"
                            description_tag="Set local timezone for time display"
                            options="" callback="on_timezone_changed"/>
      <!-- Time Format Dropdown -->
      <setting_dropdown_row name="row_time_format"
                            label="Time Format" label_tag="Time Format" icon="clock"
                            description="Choose 12-hour or 24-hour time display"
                            description_tag="Choose 12-hour or 24-hour time display" options="12 Hour&#10;24 Hour"
                            options_tag="12 Hour&#10;24 Hour" callback="on_time_format_changed"/>
      <!-- Animations Toggle -->
      <setting_toggle_row name="row_animations"
                          label="Animations" label_tag="Animations" icon="animation"
                          description="Enable UI motion effects" description_tag="Enable UI motion effects"
                          callback="on_animations_changed"/>
      <!-- System Keyboard (Android only — hidden on other platforms) -->
      <setting_toggle_row name="row_system_keyboard"
                          label="System Keyboard" label_tag="System Keyboard" icon="pencil"
                          description="Use Android native keyboard for text input"
                          description_tag="Use Android native keyboard for text input"
                          subject="settings_use_system_keyboard"
                          callback="on_system_keyboard_changed">
        <bind_flag_if_eq subject="settings_is_android" flag="hidden" ref_value="0"/>
      </setting_toggle_row>
      <!-- Widget Labels -->
      <setting_toggle_row name="row_widget_labels"
                          label="Widget Labels" label_tag="Widget Labels" icon="view_grid"
                          description="Show text labels on icon-only home screen widgets"
                          description_tag="Show text labels on icon-only home screen widgets"
                          subject="show_widget_labels"
                          callback="on_widget_labels_changed"/>
      <!-- Bed Mesh Render Mode -->
      <setting_dropdown_row name="row_bed_mesh_mode"
                            label="Bed Mesh Render" label_tag="Bed Mesh Render" icon="grid_large"
                            description="Choose rendering mode for bed mesh visualization"
                            description_tag="Choose rendering mode for bed mesh visualization"
                            options="Auto&#10;3D View&#10;2D Heatmap" options_tag="Auto&#10;3D View&#10;2D Heatmap" callback="on_bed_mesh_mode_changed"/>
      <!-- ================================================================== -->
      <!-- DISPLAY SECTION -->
      <!-- ================================================================== -->
      <setting_section_header title="DISPLAY" title_tag="DISPLAY" icon="light"/>
      <!-- Dark Mode Toggle -->
      <setting_toggle_row name="row_dark_mode"
                          label="Dark Mode" label_tag="Dark Mode" icon="light_off"
                          description="Switch between light and dark themes"
                          description_tag="Switch between light and dark themes" subject="settings_dark_mode"
                          callback="on_dark_mode_changed">
        <bind_state_if_eq subject="settings_dark_mode_available" state="disabled" ref_value="0"/>
      </setting_toggle_row>
      <!-- Theme Colors -->
      <setting_action_row name="row_theme_settings"
                          label="Theme Colors" label_tag="Theme Colors" icon="tune"
                          description="Explore palette and preview" description_tag="Explore palette and preview"
                          callback="on_theme_settings_clicked"/>
      <!-- Brightness (conditional - hidden when no hardware backlight) -->
      <lv_obj name="brightness_section"
              width="100%" height="content" scrollable="false" style_pad_left="#space_lg" style_pad_right="#space_lg"
              style_pad_top="#space_md" style_pad_bottom="#space_md" flex_flow="column" style_pad_gap="#space_xs">
        <bind_flag_if_eq subject="settings_has_dimming" flag="hidden" ref_value="0"/>
        <!-- Label row with value display -->
        <lv_obj width="100%"
                height="content" flex_flow="row" style_flex_main_place="space_between" style_flex_cross_place="center"
                style_pad_all="0" scrollable="false">
          <lv_obj height="content"
                  flex_flow="row" style_flex_cross_place="center" style_pad_gap="#space_sm" style_pad_all="0"
                  scrollable="false">
            <icon src="light" size="sm" variant="secondary"/>
            <text_body text="Brightness" translation_tag="Brightness"/>
          </lv_obj>
          <text_body name="brightness_value_label" bind_text="brightness_value"/>
        </lv_obj>
        <!-- Description -->
        <text_small text="Adjust screen brightness level" translation_tag="Adjust screen brightness level"/>
        <!-- Slider with min/max icons -->
        <lv_obj width="100%"
                height="content" flex_flow="row" style_flex_cross_place="center" style_pad_left="0" style_pad_right="0"
                style_pad_top="#space_md" style_pad_bottom="#space_md" style_pad_gap="#space_sm" scrollable="false">
          <icon src="light_off" size="xs" variant="secondary"/>
          <lv_slider name="brightness_slider" flex_grow="1" min_value="10" max_value="100" value="50">
            <event_cb trigger="value_changed" callback="on_brightness_changed"/>
          </lv_slider>
          <icon src="light" size="xs" variant="primary"/>
        </lv_obj>
      </lv_obj>
      <!-- Screen Dim -->
      <setting_dropdown_row name="row_display_dim"
                            label="Screen Dim" label_tag="Screen Dim" icon="lightbulb_on_50"
                            description="Screen dims to lower brightness after period of inactivity"
                            description_tag="Screen dims to lower brightness after period of inactivity"
                            options="Never&#10;30 seconds&#10;1 minute&#10;2 minutes&#10;5 minutes&#10;10 minutes"
                            options_tag="Never&#10;30 seconds&#10;1 minute&#10;2 minutes&#10;5 minutes&#10;10 minutes"
                            callback="on_dim_changed">
        <bind_flag_if_eq subject="settings_has_dimming" flag="hidden" ref_value="0"/>
      </setting_dropdown_row>
      <!-- Display Sleep -->
      <setting_dropdown_row name="row_display_sleep"
                            label="Display Sleep" label_tag="Display Sleep" icon="clock"
                            description="Screen sleeps after the selected period of inactivity"
                            description_tag="Screen sleeps after the selected period of inactivity"
                            options="Never&#10;1 minute&#10;5 minutes&#10;10 minutes&#10;20 minutes&#10;30 minutes"
                            options_tag="Never&#10;1 minute&#10;5 minutes&#10;10 minutes&#10;20 minutes&#10;30 minutes"
                            callback="on_sleep_changed"/>
      <!-- Screensaver -->
      <setting_dropdown_row name="row_screensaver"
                            label="Screensaver" label_tag="Screensaver" icon="television_classic"
                            description="Show instead of dimming"
                            description_tag="Show instead of dimming"
                            options="Off&#10;Flying Toasters&#10;Starfield&#10;3D Pipes"
                            options_tag="Off&#10;Flying Toasters&#10;Starfield&#10;3D Pipes"
                            callback="on_screensaver_changed"/>
      <!-- Sleep While Printing -->
      <setting_toggle_row name="row_sleep_while_printing"
                          label="Sleep While Printing" label_tag="Sleep While Printing" icon="sleep"
                          description="Allow display to sleep during active prints"
                          description_tag="Allow display to sleep during active prints"
                          callback="on_sleep_while_printing_changed"/>
      <!-- Info Note -->
      <info_note icon="info"
                 text="Touch screen to wake from sleep" translation_tag="Touch screen to wake from sleep"
                 style_pad_left="#space_lg" style_pad_right="#space_lg"/>
      <!-- ================================================================== -->
      <!-- SOUND SECTION -->
      <!-- ================================================================== -->
      <setting_section_header title="SOUND" title_tag="SOUND" icon="notifications"/>
      <!-- Master Sounds Toggle -->
      <lv_obj name="container_sounds" width="100%" style_pad_all="0" scrollable="false">
        <bind_flag_if_eq subject="printer_has_speaker" flag="hidden" ref_value="0"/>
        <setting_toggle_row name="row_sounds"
                            label="Sounds" label_tag="Sounds" icon="notifications" description="Enable audio feedback"
                            description_tag="Enable audio feedback" callback="on_sounds_changed"/>
      </lv_obj>
      <!-- Volume Slider (hidden when master sounds off) -->
      <lv_obj name="container_volume" width="100%" style_pad_all="0" scrollable="false">
        <bind_flag_if_eq subject="settings_sounds_enabled" flag="hidden" ref_value="0"/>
        <setting_slider_row name="row_volume"
                            label="Volume" label_tag="Volume" icon="volume_high" description="Master volume level"
                            description_tag="Master volume level" min="0" max="100" value="80" min_icon="volume_off"
                            max_icon="volume_high" callback="on_volume_changed"/>
      </lv_obj>
      <!-- UI Sounds Toggle (hidden when master sounds off) -->
      <lv_obj name="container_ui_sounds" width="100%" style_pad_all="0" scrollable="false">
        <bind_flag_if_eq subject="settings_sounds_enabled" flag="hidden" ref_value="0"/>
        <setting_toggle_row name="row_ui_sounds"
                            label="UI Sounds" label_tag="UI Sounds" icon="notifications"
                            description="Button taps and navigation sounds"
                            description_tag="Button taps and navigation sounds" subject="settings_ui_sounds_enabled"
                            callback="on_ui_sounds_changed"/>
      </lv_obj>
      <!-- Sound Theme Dropdown (hidden when master sounds off) -->
      <lv_obj name="container_sound_theme" width="100%" style_pad_all="0" scrollable="false">
        <bind_flag_if_eq subject="settings_sounds_enabled" flag="hidden" ref_value="0"/>
        <setting_dropdown_row name="row_sound_theme"
                              label="Sound Theme" label_tag="Sound Theme" icon="tune" description="Choose sound style"
                              description_tag="Choose sound style" callback="on_sound_theme_changed"/>
      </lv_obj>
      <!-- Test Sound (hidden when master sounds off) -->
      <lv_obj name="container_test_beep" width="100%" style_pad_all="0" scrollable="false">
        <bind_flag_if_eq subject="settings_sounds_enabled" flag="hidden" ref_value="0"/>
        <setting_action_row name="row_test_beep"
                            label="Test Sound" label_tag="Test Sound" icon="play" description="Play a test beep"
                            description_tag="Play a test beep" callback="on_test_beep"/>
      </lv_obj>
      <!-- Test Tracker (hidden when master sounds off) -->
      <lv_obj name="container_test_tracker" width="100%" style_pad_all="0" scrollable="false">
        <bind_flag_if_eq subject="settings_sounds_enabled" flag="hidden" ref_value="0"/>
        <setting_action_row name="row_test_tracker"
                            label="Test Tracker" label_tag="Test Tracker" icon="tune" description="Play / stop Crockett's Theme"
                            description_tag="Play / stop Crockett's Theme" callback="on_test_tracker"/>
      </lv_obj>
      <!-- Bottom padding for scroll -->
      <lv_obj width="100%" height="#space_lg" scrollable="false"/>
    </lv_obj>
  </view>
</component>
