<!-- PID Tuning Calibration Panel -->
<!-- Interactive calibration using PID_CALIBRATE command for extruder or bed -->
<component>
  <styles>
    <style name="pid_heater_selected" bg_color="#tertiary" bg_opa="255"/>
    <style name="pid_heater_unselected" bg_color="#elevated_bg" bg_opa="255"/>
  </styles>
  <view name="calibration_pid_panel"
        extends="lv_obj" width="#overlay_panel_width" height="100%" align="right_mid" style_bg_opa="255"
        style_bg_color="#card_bg" style_pad_all="0" style_border_width="0" scrollable="false" flex_flow="column">
    <!-- Header Bar -->
    <header_bar name="overlay_header"
                title="Automatic Heater Control Calibration" title_tag="Automatic Heater Control Calibration"
                hide_action_button="false" action_button_text="Start" action_button_text_tag="Start" action_button_callback="on_pid_start"
                action_button_disabled_subject="pid_cal_not_idle"/>
    <!-- Content Area -->
    <lv_obj name="overlay_content"
            width="100%" flex_grow="1" style_pad_all="#space_lg" flex_flow="column" style_pad_gap="#space_lg"
            scrollable="false">
      <!-- Disable content when printer not connected or klippy not ready -->
      <bind_state_if_not_eq subject="nav_buttons_enabled" state="disabled" ref_value="1"/>
      <!-- ================================================================== -->
      <!-- STATE: IDLE - Heater selection and target temperature -->
      <!-- ================================================================== -->
      <lv_obj name="state_idle"
              width="100%" flex_grow="1" style_pad_all="0" flex_flow="column" style_flex_main_place="start"
              style_flex_cross_place="center" style_pad_gap="#space_sm" scrollable="false">
        <bind_flag_if_not_eq subject="pid_cal_state" flag="hidden" ref_value="0"/>
        <!-- Scrollable content -->
        <lv_obj name="idle_scroll"
                width="100%" flex_grow="1" style_pad_all="0" flex_flow="column" style_pad_gap="#space_sm"
                scrollable="true">
          <!-- Description -->
          <text_small width="100%"
                      text="Optimizes temperature control for stable, consistent heating."
                      translation_tag="Optimizes temperature control for stable, consistent heating."
                      style_text_color="#text_muted" style_text_align="center"/>
          <!-- Method + Heater Selection (combined row) -->
          <lv_obj width="100%"
                  height="content" style_bg_color="#section_bg_color" style_radius="#border_radius"
                  style_pad_all="#space_sm" flex_flow="row" style_pad_gap="#space_md" style_flex_cross_place="center"
                  scrollable="false">
            <!-- Method selector (Kalico only, beta-gated via C++ cal_is_kalico subject) -->
            <lv_obj name="method_selector" width="1" flex_grow="1" height="content" style_pad_all="0"
                    flex_flow="row" style_pad_gap="#space_xs" style_flex_cross_place="center"
                    scrollable="false" style_flex_track_place="center">
              <bind_flag_if_eq subject="cal_is_kalico" flag="hidden" ref_value="0"/>
              <lv_obj width="content" height="content" style_pad_all="0" flex_flow="column"
                      style_pad_gap="2" style_flex_cross_place="center" scrollable="false">
                <text_body text="Method" translation_tag="Method"/>
                <beta_badge/>
              </lv_obj>
              <ui_button name="btn_method_mpc" flex_grow="1" text="MPC">
                <bind_style name="pid_heater_selected" subject="cal_method_is_mpc" ref_value="1"/>
                <bind_style name="pid_heater_unselected" subject="cal_method_is_mpc" ref_value="0"/>
                <event_cb trigger="clicked" callback="on_cal_method_mpc"/>
              </ui_button>
              <ui_button name="btn_method_pid" flex_grow="1" text="PID">
                <bind_style name="pid_heater_selected" subject="cal_method_is_mpc" ref_value="0"/>
                <bind_style name="pid_heater_unselected" subject="cal_method_is_mpc" ref_value="1"/>
                <event_cb trigger="clicked" callback="on_cal_method_pid"/>
              </ui_button>
              <divider_vertical/>
            </lv_obj>
            <!-- Heater selector -->
            <lv_obj width="1" flex_grow="1" height="content" style_pad_all="0"
                    flex_flow="row" style_pad_gap="#space_xs" style_flex_cross_place="center" scrollable="false">
              <text_body text="Heater" translation_tag="Heater"/>
              <ui_button name="btn_heater_extruder" flex_grow="1" text="Extruder" translation_tag="Extruder">
                <bind_style name="pid_heater_selected" subject="pid_heater_is_extruder" ref_value="1"/>
                <bind_style name="pid_heater_unselected" subject="pid_heater_is_extruder" ref_value="0"/>
                <event_cb trigger="clicked" callback="on_pid_heater_extruder"/>
              </ui_button>
              <ui_button name="btn_heater_bed" flex_grow="1" text="Heated Bed" translation_tag="Heated Bed">
                <bind_style name="pid_heater_selected" subject="pid_heater_is_extruder" ref_value="0"/>
                <bind_style name="pid_heater_unselected" subject="pid_heater_is_extruder" ref_value="1"/>
                <event_cb trigger="clicked" callback="on_pid_heater_bed"/>
              </ui_button>
            </lv_obj>
          </lv_obj>
          <!-- Two-column row: Temperature (left) + Fan slider (right) -->
          <lv_obj width="100%"
                  height="content" style_pad_all="0" flex_flow="row" style_pad_gap="#space_md" scrollable="false">
            <!-- Left column: Target Temperature -->
            <lv_obj height="content"
                    flex_grow="1" style_bg_color="#section_bg_color" style_radius="#border_radius"
                    style_pad_all="#space_md" flex_flow="column" style_pad_gap="#space_sm">
              <text_body text="Target Temperature" translation_tag="Target Temperature"/>
              <!-- Material Presets (Extruder) -->
              <lv_obj name="extruder_presets"
                      width="100%" height="content" style_pad_all="0" flex_flow="row" style_pad_gap="#space_xs"
                      style_flex_main_place="start" scrollable="false">
                <bind_flag_if_eq subject="pid_heater_is_extruder" flag="hidden" ref_value="0"/>
                <ui_button name="btn_preset_pla" flex_grow="1" height="#button_height_sm" text="PLA" style_text_font="#font_small">
                  <event_cb trigger="clicked" callback="on_pid_preset_pla"/>
                </ui_button>
                <ui_button name="btn_preset_petg" flex_grow="1" height="#button_height_sm" text="PETG" style_text_font="#font_small">
                  <event_cb trigger="clicked" callback="on_pid_preset_petg"/>
                </ui_button>
                <ui_button name="btn_preset_abs" flex_grow="1" height="#button_height_sm" text="ABS" style_text_font="#font_small">
                  <event_cb trigger="clicked" callback="on_pid_preset_abs"/>
                </ui_button>
                <ui_button name="btn_preset_pa" flex_grow="1" height="#button_height_sm" text="PA" style_text_font="#font_small">
                  <event_cb trigger="clicked" callback="on_pid_preset_pa"/>
                </ui_button>
                <ui_button name="btn_preset_tpu" flex_grow="1" height="#button_height_sm" text="TPU" style_text_font="#font_small">
                  <event_cb trigger="clicked" callback="on_pid_preset_tpu"/>
                </ui_button>
              </lv_obj>
              <!-- Material Presets (Bed) -->
              <lv_obj name="bed_presets"
                      width="100%" height="content" style_pad_all="0" flex_flow="row" style_pad_gap="#space_xs"
                      style_flex_main_place="start" scrollable="false">
                <bind_flag_if_not_eq subject="pid_heater_is_extruder" flag="hidden" ref_value="0"/>
                <ui_button name="btn_preset_bed_pla" flex_grow="1" height="#button_height_sm" text="PLA" style_text_font="#font_small">
                  <event_cb trigger="clicked" callback="on_pid_preset_bed_pla"/>
                </ui_button>
                <ui_button name="btn_preset_bed_petg" flex_grow="1" height="#button_height_sm" text="PETG" style_text_font="#font_small">
                  <event_cb trigger="clicked" callback="on_pid_preset_bed_petg"/>
                </ui_button>
                <ui_button name="btn_preset_bed_abs" flex_grow="1" height="#button_height_sm" text="ABS" style_text_font="#font_small">
                  <event_cb trigger="clicked" callback="on_pid_preset_bed_abs"/>
                </ui_button>
              </lv_obj>
              <!-- Temperature: [-] 200°C [+] -->
              <lv_obj width="100%"
                      height="#button_height" style_pad_all="0" flex_flow="row" style_flex_main_place="center"
                      style_flex_cross_place="center" style_pad_gap="#space_md" scrollable="false">
                <ui_button name="btn_temp_down" width="#button_height" height="#button_height" text="-">
                  <event_cb trigger="clicked" callback="on_pid_temp_down"/>
                </ui_button>
                <lv_label name="temp_display"
                          flex_grow="1" text="200°C" style_text_font="#font_heading"
                          style_text_align="center" bind_text="pid_temp_display"/>
                <ui_button name="btn_temp_up" width="#button_height" height="#button_height" text="+">
                  <event_cb trigger="clicked" callback="on_pid_temp_up"/>
                </ui_button>
              </lv_obj>
            </lv_obj>
            <!-- Vertical divider -->
            <divider_vertical/>
            <!-- Right column: Fan + Warning (always visible) -->
            <lv_obj height="content" flex_grow="1" style_pad_all="0" flex_flow="column" style_pad_gap="#space_sm">
              <!-- Part Cooling Fan (PID + extruder only) -->
              <lv_obj name="fan_speed_section"
                      width="100%" height="content" style_bg_color="#section_bg_color" style_radius="#border_radius"
                      style_pad_all="#space_md" flex_flow="column" style_pad_gap="#space_sm"
                      style_flex_main_place="center">
                <bind_flag_if_eq subject="cal_show_pid_fan" flag="hidden" ref_value="0"/>
                <text_body text="Part Cooling Fan" translation_tag="Part Cooling Fan"/>
                <lv_obj width="100%"
                        height="content" style_pad_top="#space_xs" style_pad_bottom="#space_xs"
                        style_pad_left="#space_lg" style_pad_right="#space_md" flex_flow="row"
                        style_flex_cross_place="center" style_pad_gap="#space_md" scrollable="false">
                  <lv_slider name="fan_speed_slider" flex_grow="1" min_value="0" max_value="100" value="0"/>
                  <lv_label name="fan_speed_label"
                            width="40" text="0%" style_text_font="#font_small" style_text_align="right"
                            bind_text="cal_fan_speed_text"/>
                </lv_obj>
                <text_small text="Match your typical print fan speed"
                            translation_tag="Match your typical print fan speed" style_text_color="#text_muted"/>
              </lv_obj>
              <!-- Fan Calibration (MPC + extruder only) -->
              <lv_obj name="fan_calibration_section"
                      width="100%" height="content" style_bg_color="#section_bg_color" style_radius="#border_radius"
                      style_pad_all="#space_md" flex_flow="column" style_pad_gap="#space_sm">
                <bind_flag_if_eq subject="cal_show_fan_config" flag="hidden" ref_value="0"/>
                <text_body text="Fan Calibration" translation_tag="Fan Calibration"/>
                <lv_obj width="100%"
                        height="content" style_pad_all="0" flex_flow="row" style_pad_gap="#space_xs" scrollable="false">
                  <ui_button name="btn_fan_quick"
                             height="#button_height_sm" flex_grow="1" text="Quick" translation_tag="Quick"
                             style_text_font="#font_small">
                    <bind_style name="pid_heater_selected" subject="cal_fan_is_quick" ref_value="1"/>
                    <bind_style name="pid_heater_unselected" subject="cal_fan_is_quick" ref_value="0"/>
                    <event_cb trigger="clicked" callback="on_cal_fan_quick"/>
                  </ui_button>
                  <ui_button name="btn_fan_detailed"
                             height="#button_height_sm" flex_grow="1" text="Detailed" translation_tag="Detailed"
                             style_text_font="#font_small">
                    <bind_style name="pid_heater_selected" subject="cal_fan_is_detailed" ref_value="1"/>
                    <bind_style name="pid_heater_unselected" subject="cal_fan_is_detailed" ref_value="0"/>
                    <event_cb trigger="clicked" callback="on_cal_fan_detailed"/>
                  </ui_button>
                  <ui_button name="btn_fan_thorough"
                             height="#button_height_sm" flex_grow="1" text="Thorough" translation_tag="Thorough"
                             style_text_font="#font_small">
                    <bind_style name="pid_heater_selected" subject="cal_fan_is_thorough" ref_value="1"/>
                    <bind_style name="pid_heater_unselected" subject="cal_fan_is_thorough" ref_value="0"/>
                    <event_cb trigger="clicked" callback="on_cal_fan_thorough"/>
                  </ui_button>
                </lv_obj>
                <text_small width="100%" text="More points = more accurate, but takes longer."
                            translation_tag="More points = more accurate, but takes longer."
                            style_text_color="#text_muted" long_mode="wrap"/>
              </lv_obj>
              <!-- Heater Wattage (MPC migration only) -->
              <lv_obj name="wattage_section"
                      width="100%" height="content" style_bg_color="#section_bg_color" style_radius="#border_radius"
                      style_pad_all="#space_md" flex_flow="column" style_pad_gap="#space_sm">
                <bind_flag_if_eq subject="cal_show_wattage" flag="hidden" ref_value="0"/>
                <text_body text="Heater Power" translation_tag="Heater Power"/>
                <lv_obj width="100%"
                        height="#button_height" style_pad_all="0" flex_flow="row" style_flex_main_place="center"
                        style_flex_cross_place="center" style_pad_gap="#space_md" scrollable="false">
                  <ui_button name="btn_wattage_down" width="#button_height" height="#button_height" text="-">
                    <event_cb trigger="clicked" callback="on_cal_wattage_down"/>
                  </ui_button>
                  <lv_label name="wattage_display"
                            flex_grow="1" text="50W" style_text_font="#font_heading" style_text_align="center"
                            bind_text="cal_wattage_display"/>
                  <ui_button name="btn_wattage_up" width="#button_height" height="#button_height" text="+">
                    <event_cb trigger="clicked" callback="on_cal_wattage_up"/>
                  </ui_button>
                </lv_obj>
                <text_small text="Check your heater's rating (typically 40-60W for hotends)"
                            translation_tag="Check your heater's rating (typically 40-60W for hotends)"
                            style_text_color="#text_muted"/>
              </lv_obj>
            </lv_obj>
          </lv_obj>
        </lv_obj>
        <!-- Footer warnings (outside scroll, always at bottom) -->
        <lv_obj width="100%" height="content" style_pad_all="0" flex_flow="column"
                style_pad_gap="#space_xs" scrollable="false">
          <!-- Migration warning (MPC needs config change) -->
          <lv_obj name="migration_warning"
                  width="100%" height="content" style_pad_all="#space_xs" flex_flow="row"
                  style_flex_cross_place="center" style_pad_gap="#space_sm" scrollable="false">
            <bind_flag_if_eq subject="cal_needs_migration" flag="hidden" ref_value="0"/>
            <icon src="alert" size="sm" variant="warning"/>
            <text_small text="Switching to MPC requires a config change and Klipper restart."
                        translation_tag="Switching to MPC requires a config change and Klipper restart."
                        style_text_color="#text_muted" flex_grow="1"/>
          </lv_obj>
          <!-- Duration warning (always visible) -->
          <lv_obj width="100%" height="content" style_pad_all="#space_xs" flex_flow="row"
                  style_flex_cross_place="center" style_pad_gap="#space_sm" scrollable="false">
            <icon src="alert" size="sm" variant="warning"/>
            <text_small text="Takes 3-5 min. Do not interrupt."
                        translation_tag="Takes 3-5 min. Do not interrupt." style_text_color="#text_muted"
                        flex_grow="1"/>
          </lv_obj>
        </lv_obj>
      </lv_obj>
      <!-- ================================================================== -->
      <!-- STATE: CALIBRATING - Progress display -->
      <!-- ================================================================== -->
      <lv_obj name="state_calibrating"
              width="100%" flex_grow="1" style_pad_all="0" flex_flow="column" style_flex_main_place="space_around"
              style_flex_cross_place="center" style_flex_track_place="center" style_pad_gap="#space_sm"
              scrollable="false">
        <bind_flag_if_not_eq subject="pid_cal_state" flag="hidden" ref_value="1"/>
        <!-- Top row: spinner+status (left) | graph+temp (right) -->
        <lv_obj width="100%"
                flex_grow="1" style_pad_all="0" flex_flow="row" style_flex_cross_place="center"
                style_pad_gap="#space_lg" scrollable="false">
          <!-- Left: progress + labels -->
          <lv_obj height="100%"
                  style_pad_all="#space_md" flex_flow="column" style_flex_cross_place="center"
                  style_flex_main_place="center" style_flex_track_place="center" style_pad_gap="#space_sm" flex_grow="1">
            <text_heading text="Calibrating..." translation_tag="Calibrating..." style_text_align="center"/>
            <text_muted name="calibrating_heater"
                        text="Extruder PID Tuning" translation_tag="Extruder PID Tuning"
                        bind_text="pid_calibrating_heater"/>
            <progress_bar name="pid_progress_bar" width="80%" bind_value="pid_cal_progress"/>
            <text_small name="pid_progress_text"
                        bind_text="pid_progress_text" text="Starting..." style_text_color="#text_muted"/>
          </lv_obj>
          <!-- Right: temperature graph + live display -->
          <lv_obj height="100%"
                  flex_grow="1" style_bg_color="#section_bg_color" style_radius="#border_radius"
                  style_pad_all="#space_md" flex_flow="column" style_flex_cross_place="center" style_pad_gap="#space_sm">
            <!-- Temperature graph (populated by C++) -->
            <lv_obj name="pid_temp_graph_container" width="100%" flex_grow="1" style_pad_all="0" scrollable="false"/>
            <!-- Extruder temp (shown when extruder selected) -->
            <lv_obj width="content" height="content" style_pad_all="0" scrollable="false">
              <bind_flag_if_eq subject="pid_heater_is_extruder" flag="hidden" ref_value="0"/>
              <temp_display size="lg" show_target="true" bind_current="extruder_temp" bind_target="extruder_target"/>
            </lv_obj>
            <!-- Bed temp (shown when bed selected) -->
            <lv_obj width="content" height="content" style_pad_all="0" scrollable="false">
              <bind_flag_if_not_eq subject="pid_heater_is_extruder" flag="hidden" ref_value="0"/>
              <temp_display size="lg" show_target="true" bind_current="bed_temp" bind_target="bed_target"/>
            </lv_obj>
            <text_small text="Current Temperature" translation_tag="Current Temperature" style_text_color="#text_muted"/>
          </lv_obj>
        </lv_obj>
        <text_small width="80%"
                    text="The heater will cycle on and off several times."
                    translation_tag="The heater will cycle on and off several times." style_text_align="center"
                    style_text_color="#text_muted"/>
        <!-- Abort Button -->
        <ui_button name="btn_abort" width="25%" text="Abort" translation_tag="Abort" variant="danger">
          <event_cb trigger="clicked" callback="on_pid_abort"/>
        </ui_button>
      </lv_obj>
      <!-- ================================================================== -->
      <!-- STATE: SAVING - Saving configuration -->
      <!-- ================================================================== -->
      <lv_obj name="state_saving"
              width="100%" flex_grow="1" style_pad_all="0" flex_flow="column" style_flex_main_place="center"
              style_flex_cross_place="center" style_flex_track_place="center" style_pad_gap="#space_lg"
              scrollable="false">
        <bind_flag_if_not_eq subject="pid_cal_state" flag="hidden" ref_value="2"/>
        <spinner size="lg"/>
        <text_heading text="Saving Configuration..." translation_tag="Saving Configuration..." style_text_align="center"/>
        <text_small width="80%"
                    text="Klipper will restart to apply new settings."
                    translation_tag="Klipper will restart to apply new settings." style_text_align="center"/>
      </lv_obj>
      <!-- ================================================================== -->
      <!-- STATE: COMPLETE - Results display -->
      <!-- ================================================================== -->
      <lv_obj name="state_complete"
              width="100%" flex_grow="1" style_pad_all="0" flex_flow="column" style_flex_main_place="center"
              style_flex_cross_place="center" style_flex_track_place="center" style_pad_gap="#space_md"
              scrollable="false">
        <bind_flag_if_not_eq subject="pid_cal_state" flag="hidden" ref_value="3"/>
        <!-- Title row: icon + heading inline -->
        <lv_obj width="content" height="content" style_pad_all="0" flex_flow="row"
                style_flex_cross_place="center" style_pad_gap="#space_sm" scrollable="false">
          <icon src="check_circle" size="md" variant="success"/>
          <text_heading text="Calibration Complete!" translation_tag="Calibration Complete!"/>
        </lv_obj>
        <text_body name="pid_result_summary"
                   width="80%" bind_text="pid_result_summary" text="Temperature control has been optimized."
                   style_text_align="center" style_text_color="#text_muted"/>
        <!-- PID Technical details (hidden when MPC) -->
        <lv_obj name="pid_results"
                width="70%" height="content" style_bg_color="#section_bg_color" style_radius="#border_radius"
                style_pad_all="#space_md" flex_flow="column" style_pad_gap="#space_xs">
          <bind_flag_if_eq subject="cal_method_is_mpc" flag="hidden" ref_value="1"/>
          <lv_obj width="100%"
                  height="content" style_pad_all="0" flex_flow="row" style_flex_main_place="space_between"
                  scrollable="false">
            <text_small text="Response (Kp)" translation_tag="Response (Kp)" style_text_color="#text_muted"/>
            <text_small name="pid_kp" bind_text="pid_kp" text="0.000"/>
          </lv_obj>
          <lv_obj width="100%"
                  height="content" style_pad_all="0" flex_flow="row" style_flex_main_place="space_between"
                  scrollable="false">
            <text_small text="Correction (Ki)" translation_tag="Correction (Ki)" style_text_color="#text_muted"/>
            <text_small name="pid_ki" bind_text="pid_ki" text="0.000"/>
          </lv_obj>
          <lv_obj width="100%"
                  height="content" style_pad_all="0" flex_flow="row" style_flex_main_place="space_between"
                  scrollable="false">
            <text_small text="Damping (Kd)" translation_tag="Damping (Kd)" style_text_color="#text_muted"/>
            <text_small name="pid_kd" bind_text="pid_kd" text="0.000"/>
          </lv_obj>
        </lv_obj>
        <!-- MPC Technical details (shown when MPC) -->
        <lv_obj name="mpc_results"
                width="70%" height="content" style_bg_color="#section_bg_color" style_radius="#border_radius"
                style_pad_all="#space_md" flex_flow="column" style_pad_gap="#space_xs">
          <bind_flag_if_eq subject="cal_method_is_mpc" flag="hidden" ref_value="0"/>
          <lv_obj width="100%"
                  height="content" style_pad_all="0" flex_flow="row" style_flex_main_place="space_between"
                  scrollable="false">
            <text_small text="Heat Capacity" translation_tag="Heat Capacity" style_text_color="#text_muted"/>
            <text_small bind_text="mpc_block_heat_capacity" text="0.0000 J/K"/>
          </lv_obj>
          <lv_obj width="100%"
                  height="content" style_pad_all="0" flex_flow="row" style_flex_main_place="space_between"
                  scrollable="false">
            <text_small text="Sensor Response" translation_tag="Sensor Response" style_text_color="#text_muted"/>
            <text_small bind_text="mpc_sensor_responsiveness" text="0.000000 K/s/K"/>
          </lv_obj>
          <lv_obj width="100%"
                  height="content" style_pad_all="0" flex_flow="row" style_flex_main_place="space_between"
                  scrollable="false">
            <text_small text="Ambient Transfer" translation_tag="Ambient Transfer" style_text_color="#text_muted"/>
            <text_small bind_text="mpc_ambient_transfer" text="0.000000 W/K"/>
          </lv_obj>
          <lv_obj width="100%"
                  height="content" style_pad_all="0" flex_flow="row" style_flex_main_place="space_between"
                  scrollable="false">
            <text_small text="Fan Transfer" translation_tag="Fan Transfer" style_text_color="#text_muted"/>
            <text_small bind_text="mpc_fan_ambient_transfer" text=""/>
          </lv_obj>
        </lv_obj>
        <text_small width="80%"
                    text="Saved to printer configuration." translation_tag="Saved to printer configuration."
                    style_text_align="center" style_text_color="#text_muted"/>
        <!-- Spacer pushes Done button to bottom -->
        <lv_obj width="0" flex_grow="1" style_pad_all="0" scrollable="false"/>
        <ui_button name="btn_done" width="140" height="#button_height" text="Done" translation_tag="Done">
          <event_cb trigger="clicked" callback="on_pid_done"/>
        </ui_button>
      </lv_obj>
      <!-- ================================================================== -->
      <!-- STATE: ERROR - Something went wrong -->
      <!-- ================================================================== -->
      <lv_obj name="state_error"
              width="100%" flex_grow="1" style_pad_all="0" flex_flow="column" style_flex_main_place="center"
              style_flex_cross_place="center" style_flex_track_place="center" style_pad_gap="#space_lg"
              scrollable="false">
        <bind_flag_if_not_eq subject="pid_cal_state" flag="hidden" ref_value="4"/>
        <icon src="close_circle" size="lg" variant="danger"/>
        <text_heading text="Calibration Failed" translation_tag="Calibration Failed" style_text_align="center"/>
        <text_muted name="error_message"
                    width="80%" text="An error occurred during calibration."
                    translation_tag="An error occurred during calibration." style_text_align="center" long_mode="wrap"
                    bind_text="pid_error_message"/>
        <lv_obj width="100%"
                height="#button_height" style_pad_all="0" flex_flow="row" style_flex_main_place="center" style_pad_gap="#space_md"
                scrollable="false">
          <ui_button name="btn_close_error" width="140" text="Close" translation_tag="Close">
            <event_cb trigger="clicked" callback="on_pid_done"/>
          </ui_button>
          <ui_button name="btn_retry" width="140" text="Retry" translation_tag="Retry" variant="primary">
            <event_cb trigger="clicked" callback="on_pid_retry"/>
          </ui_button>
        </lv_obj>
      </lv_obj>
      <!-- ================================================================== -->
      <!-- STATE: MIGRATING - Updating config for MPC -->
      <!-- ================================================================== -->
      <lv_obj name="state_migrating"
              width="100%" flex_grow="1" style_pad_all="0" flex_flow="column" style_flex_main_place="center"
              style_flex_cross_place="center" style_flex_track_place="center" style_pad_gap="#space_lg"
              scrollable="false">
        <bind_flag_if_not_eq subject="pid_cal_state" flag="hidden" ref_value="5"/>
        <spinner size="lg"/>
        <text_heading text="Updating Configuration..."
                      translation_tag="Updating Configuration..." style_text_align="center"/>
        <text_small width="80%"
                    text="Switching heater control to MPC. Klipper will restart."
                    translation_tag="Switching heater control to MPC. Klipper will restart." style_text_align="center"
                    style_text_color="#text_muted"/>
      </lv_obj>
    </lv_obj>
  </view>
</component>
