<!-- Spoolman Settings Overlay Panel -->
<!-- Configures Spoolman integration (sync, polling) and label printer settings -->
<component>
  <view name="spoolman_settings"
        extends="overlay_panel" width="#overlay_panel_width_full" title="Spoolman" title_tag="Spoolman" bg_color="#screen_bg">
    <!-- Content Area (scrollable) -->
    <lv_obj name="overlay_content"
            width="100%" flex_grow="1" style_pad_top="0" style_pad_left="#space_md" style_pad_right="#space_md" style_pad_bottom="#space_md" scrollable="true" flex_flow="column"
            style_pad_gap="#space_sm">
      <!-- Description text -->
      <text_small name="description" width="100%" text="Configure Spoolman integration and weight sync settings." translation_tag="Configure Spoolman integration and weight sync settings."/>
      <!-- ================================================================== -->
      <!-- Server Setup (shown when Spoolman NOT configured)                   -->
      <!-- ================================================================== -->
      <ui_card name="setup_card"
               width="100%" height="content" style_radius="#border_radius" style_pad_all="#space_md"
               flex_flow="column" style_pad_gap="#space_sm">
        <bind_flag_if_eq subject="printer_has_spoolman" flag="hidden" ref_value="1"/>
        <text_body text="Server Setup" translation_tag="Server Setup"/>
        <text_small text="Enter the IP address and port of your Spoolman server."
                    translation_tag="Enter the IP address and port of your Spoolman server."
                    style_text_color="#text_muted"/>
        <!-- Host + Port inputs side by side -->
        <lv_obj width="100%" height="content" style_pad_all="0" flex_flow="row"
                style_pad_gap="#space_sm" scrollable="false">
          <lv_obj height="content" flex_grow="1" style_pad_all="0" flex_flow="column"
                  style_pad_gap="#space_xs" scrollable="false">
            <text_small text="IP Address / Hostname" translation_tag="IP Address / Hostname"/>
            <text_input name="spoolman_host_input"
                        width="100%" placeholder_text="192.168.1.100" max_length="64"/>
          </lv_obj>
          <lv_obj width="80" height="content" style_pad_all="0" flex_flow="column"
                  style_pad_gap="#space_xs" scrollable="false">
            <text_small text="Port" translation_tag="Port"/>
            <text_input name="spoolman_port_input"
                        width="100%" placeholder_text="7912" max_length="5"
                        input_mode="number" keyboard_hint="numeric" text="7912"/>
          </lv_obj>
        </lv_obj>
        <!-- Status text (for errors/progress) -->
        <text_small name="setup_status_text" width="100%" text=""
                    style_text_color="#text_muted"/>
        <!-- Action buttons -->
        <lv_obj width="100%" height="content" style_pad_all="0" flex_flow="row"
                style_pad_gap="#space_sm" scrollable="false">
          <ui_button name="connect_btn" variant="primary" flex_grow="1"
                     text="Connect" translation_tag="Connect">
            <event_cb trigger="clicked" callback="on_spoolman_connect_clicked"/>
          </ui_button>
          <ui_button name="cancel_setup_btn" variant="outline" flex_grow="1"
                     text="Cancel" translation_tag="Cancel">
            <event_cb trigger="clicked" callback="on_spoolman_cancel_setup_clicked"/>
          </ui_button>
        </lv_obj>
      </ui_card>
      <!-- ================================================================== -->
      <!-- Server Status (shown when Spoolman IS configured)                   -->
      <!-- ================================================================== -->
      <ui_card name="status_card"
               width="100%" height="content" style_radius="#border_radius" style_pad_all="#space_md"
               flex_flow="column" style_pad_gap="#space_sm">
        <bind_flag_if_eq subject="printer_has_spoolman" flag="hidden" ref_value="0"/>
        <lv_obj width="100%" height="content" style_pad_all="0" flex_flow="row"
                style_flex_main_place="space_between" style_flex_cross_place="center" scrollable="false">
          <text_body text="Spoolman Server"/>
          <lv_obj height="content" style_pad_all="0" flex_flow="row"
                  style_flex_cross_place="center" style_pad_gap="#space_xs" scrollable="false">
            <text_small name="server_url_text" text="Connected" translation_tag="Connected"
                        style_text_color="#text_muted"/>
            <icon src="check_circle" size="sm" color="#success"/>
          </lv_obj>
        </lv_obj>
        <lv_obj width="100%" height="content" style_pad_all="0" flex_flow="row"
                style_pad_gap="#space_sm" scrollable="false">
          <ui_button name="change_btn" variant="outline" flex_grow="1"
                     text="Change" translation_tag="Change">
            <event_cb trigger="clicked" callback="on_spoolman_change_clicked"/>
          </ui_button>
          <ui_button name="remove_btn" variant="outline" flex_grow="1"
                     text="Remove" translation_tag="Remove">
            <event_cb trigger="clicked" callback="on_spoolman_remove_clicked"/>
          </ui_button>
        </lv_obj>
      </ui_card>
      <!-- ================================================================== -->
      <!-- Sync Settings                                                       -->
      <!-- ================================================================== -->
      <ui_card name="sync_card"
               width="100%" height="content" style_radius="#border_radius" style_pad_all="#space_md"
               flex_flow="row" style_flex_cross_place="center" style_pad_gap="0">
        <bind_flag_if_eq subject="printer_has_spoolman" flag="hidden" ref_value="0"/>
        <!-- Sync toggle -->
        <lv_obj height="content" flex_grow="1" style_pad_all="0" flex_flow="row"
                style_flex_main_place="space_between" style_flex_cross_place="center" scrollable="false">
          <lv_obj height="content"
                  style_pad_all="0" flex_flow="column" style_pad_gap="#space_xs" scrollable="false">
            <text_body text="Sync with Spoolman" translation_tag="Sync with Spoolman"/>
            <text_small text="Auto-poll for weight updates" translation_tag="Auto-poll for weight updates"/>
          </lv_obj>
          <ui_switch name="sync_toggle" size="small">
            <bind_state_if_eq subject="ams_spoolman_sync_enabled" state="checked" ref_value="1"/>
            <event_cb trigger="value_changed" callback="on_ams_spoolman_sync_toggled"/>
          </ui_switch>
        </lv_obj>
        <!-- Vertical divider -->
        <divider_vertical style_margin_left="#space_md" style_margin_right="#space_md"/>
        <!-- Refresh interval -->
        <lv_obj height="content" flex_grow="1" style_pad_all="0" flex_flow="row"
                style_flex_main_place="space_between" style_flex_cross_place="center" scrollable="false">
          <text_body text="Refresh Interval" translation_tag="Refresh Interval"/>
          <lv_dropdown name="interval_dropdown"
                       width="100" height="36" options="30s&#10;1 min&#10;2 min&#10;5 min" style_pad_left="#space_sm"
                       style_pad_right="#space_sm">
            <event_cb trigger="value_changed" callback="on_ams_spoolman_interval_changed"/>
          </lv_dropdown>
        </lv_obj>
      </ui_card>
      <!-- ================================================================== -->
      <!-- Info Note                                                          -->
      <!-- ================================================================== -->
      <lv_obj name="info_note"
              width="100%" height="content" style_pad_all="#space_sm" style_pad_left="#space_md" flex_flow="row"
              style_flex_main_place="start" style_flex_cross_place="center" style_pad_gap="#space_sm" scrollable="false">
        <bind_flag_if_eq subject="printer_has_spoolman" flag="hidden" ref_value="0"/>
        <icon src="info" size="sm" variant="secondary"/>
        <text_small width="100%" flex_grow="1"
                    text="Weight data is synced from Spoolman to display remaining filament. Changes are also synced when prints start, pause, or complete." translation_tag="Weight data is synced from Spoolman to display remaining filament. Changes are also synced when prints start, pause, or complete." style_text_color="#text_muted"/>
      </lv_obj>
      <!-- ================================================================== -->
      <!-- Label Printer (opens sub-panel)                                    -->
      <!-- ================================================================== -->
      <setting_action_row name="row_label_printer"
                          label="Label Printer" label_tag="Label Printer" icon="print"
                          description="Configure label printer and auto-discovery"
                          description_tag="Configure label printer and auto-discovery"
                          callback="on_spoolman_label_printer_clicked"/>
    </lv_obj>
  </view>
</component>
