                height="#swatch_size" style_radius="#border_radius_small" style_bg_color="0x536DFE"
                style_bg_opa="255" clickable="true" scrollable="false">
          <event_cb trigger="clicked" callback="color_swatch_clicked_cb"/>
        </lv_obj>
        <lv_obj width="#swatch_size"
                height="#swatch_size" style_radius="#border_radius_small" style_bg_color="0xEA80FC"
                style_bg_opa="255" clickable="true" scrollable="false">
          <event_cb trigger="clicked" callback="color_swatch_clicked_cb"/>
        </lv_obj>
        <lv_obj width="#swatch_size"
                height="#swatch_size" style_radius="#border_radius_small" style_bg_color="0xFF80AB"
                style_bg_opa="255" clickable="true" scrollable="false">
          <event_cb trigger="clicked" callback="color_swatch_clicked_cb"/>
        </lv_obj>
        <lv_obj width="#swatch_size"
                height="#swatch_size" style_radius="#border_radius_small" style_bg_color="0xBCAAA4"
                style_bg_opa="255" clickable="true" scrollable="false">
          <event_cb trigger="clicked" callback="color_swatch_clicked_cb"/>
        </lv_obj>
      </lv_obj>

      <!-- Custom tab content (hidden by default, C++ toggles via tab switching) -->
      <lv_obj name="custom_content" width="100%" height="content"
              style_pad_all="#space_md" flex_flow="row" style_pad_gap="#space_md"
              style_flex_main_place="center" scrollable="false" flag_hidden="true">
        <!-- LEFT: HSV picker -->
        <ui_hsv_picker name="hsv_picker_tiny" sv_size="#sv_size" hue_height="#hue_height" gap="#space_sm"/>
        <!-- RIGHT: Preview + hex input + color name stacked -->
        <lv_obj width="content" height="content"
                style_pad_all="0" flex_flow="column" style_flex_main_place="start"
                style_flex_cross_place="start" style_pad_gap="#space_sm" scrollable="false">
          <!-- Selected color preview swatch -->
          <lv_obj name="selected_color_preview_tiny"
                  width="#color_preview_size" height="#color_preview_size_small" style_radius="#border_radius"
                  style_bg_color="#card_bg" style_bg_opa="255" style_border_width="2" style_border_color="#text_muted"
                  style_border_opa="80" scrollable="false"/>
          <!-- Hex input -->
          <text_input name="hex_input_tiny"
                      width="100" height="content" max_length="9" text="#808080" placeholder_text="#RRGGBB"
                      style_border_width="0" style_outline_width="0" scrollable="false">
            <event_cb trigger="value_changed" callback="hex_input_changed_cb"/>
            <event_cb trigger="defocused" callback="hex_input_defocused_cb"/>
          </text_input>
          <!-- Color name -->
          <lv_label name="selected_name_label_tiny" text="Gray" translation_tag="Gray"
                    long_mode="wrap"/>
        </lv_obj>
      </lv_obj>
    </lv_obj>

    <!-- Flex spacer to push buttons to bottom on TINY (full-screen) -->
    <lv_obj flex_grow="1" scrollable="false">
      <bind_flag_if_gt subject="ui_breakpoint" flag="hidden" ref_value="1"/>
    </lv_obj>
    <!-- Action buttons row using standard modal component -->
    <modal_button_row secondary_text="Cancel" secondary_tag="Cancel" secondary_callback="color_picker_cancel_cb"
                      primary_text="Select" primary_tag="Select" primary_callback="color_picker_select_cb"/>
  </view>
</component>
