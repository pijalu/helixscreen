<!-- Sensors Settings Overlay -->
<!-- Configure sensor roles and enable/disable individual sensors for all sensor types -->
<!-- XML-First Design: Layout/styling here; C++ populates sensor lists dynamically -->
<component>
  <view name="sensors_overlay"
        extends="overlay_panel" width="#overlay_panel_width_full" title="Sensors" title_tag="Sensors"
        bg_color="#screen_bg">
    <!-- Content Area -->
    <lv_obj name="overlay_content"
            width="100%" flex_grow="1" style_pad_all="#space_md" style_pad_top="0" scrollable="true"
            scroll_elastic="false" flex_flow="column" style_pad_gap="#space_sm">

      <!-- ================================================================== -->
      <!-- SWITCH SENSORS SECTION (filament runout/motion sensors) -->
      <!-- ================================================================== -->
      <lv_obj name="switch_sensors_section"
              width="100%" height="content" style_bg_color="#screen_bg" style_bg_opa="255" style_radius="#border_radius"
              style_pad_all="0" scrollable="false" flex_flow="column" style_pad_gap="0">
        <bind_flag_if_eq subject="filament_sensor_count" flag="hidden" ref_value="0"/>
        <setting_section_header title="SWITCH SENSORS" title_tag="Switch Sensors" icon="electric_switch"
                                badge_name="switch_sensor_count" badge_text="0" hide_badge="false"/>
        <!-- Section content with inner padding -->
        <lv_obj width="100%" height="content" style_pad_left="#space_lg" style_pad_right="#space_lg"
                style_pad_top="#space_sm" style_pad_bottom="#space_md" scrollable="false" flex_flow="column"
                style_pad_gap="#space_sm">
          <!-- Master Enable Toggle -->
          <lv_obj width="100%"
                  height="content" style_pad_all="0" scrollable="false" flex_flow="row"
                  style_flex_main_place="space_between" style_flex_cross_place="center">
            <text_small text="Enable Monitoring" translation_tag="Enable Monitoring"/>
            <ui_switch name="switch_master_toggle" size="small">
              <bind_state_if_eq subject="filament_master_enabled" state="checked" ref_value="1"/>
              <event_cb trigger="value_changed" callback="on_switch_master_toggle_changed"/>
            </ui_switch>
          </lv_obj>
          <!-- Description -->
          <text_small width="100%"
                      text="Filament runout and motion detection sensors"
                      translation_tag="Filament runout and motion detection sensors" style_text_align="left"/>
          <!-- Sensor List Container -->
          <lv_obj name="switch_sensors_list"
                  width="100%" height="content" style_pad_all="0" scrollable="false" flex_flow="column"
                  style_pad_gap="#space_xs"/>
        </lv_obj>
      </lv_obj>

      <!-- ================================================================== -->
      <!-- PROBE SENSORS SECTION -->
      <!-- ================================================================== -->
      <lv_obj name="probe_sensors_section"
              width="100%" height="content" style_bg_color="#screen_bg" style_bg_opa="255" style_radius="#border_radius"
              style_pad_all="0" scrollable="false" flex_flow="column" style_pad_gap="0">
        <bind_flag_if_eq subject="probe_count" flag="hidden" ref_value="0"/>
        <setting_section_header title="PROBE SENSORS" title_tag="Probe Sensors" icon="arrow_down_bold"
                                badge_name="probe_sensor_count_label" badge_text="0" hide_badge="false"/>
        <lv_obj width="100%" height="content" style_pad_left="#space_lg" style_pad_right="#space_lg"
                style_pad_top="#space_sm" style_pad_bottom="#space_md" scrollable="false" flex_flow="column"
                style_pad_gap="#space_sm">
          <text_small width="100%"
                      text="Z probes for bed leveling and mesh generation"
                      translation_tag="Z probes for bed leveling and mesh generation" style_text_align="left"/>
          <lv_obj name="probe_sensors_list"
                  width="100%" height="content" style_pad_all="0" scrollable="false" flex_flow="column"
                  style_pad_gap="#space_xs"/>
        </lv_obj>
      </lv_obj>

      <!-- ================================================================== -->
      <!-- WIDTH SENSORS SECTION -->
      <!-- ================================================================== -->
      <lv_obj name="width_sensors_section"
              width="100%" height="content" style_bg_color="#screen_bg" style_bg_opa="255" style_radius="#border_radius"
              style_pad_all="0" scrollable="false" flex_flow="column" style_pad_gap="0">
        <bind_flag_if_eq subject="width_sensor_count" flag="hidden" ref_value="0"/>
        <setting_section_header title="WIDTH SENSORS" title_tag="Width Sensors" icon="ruler"
                                badge_name="width_sensor_count_label" badge_text="0" hide_badge="false"/>
        <lv_obj width="100%" height="content" style_pad_left="#space_lg" style_pad_right="#space_lg"
                style_pad_top="#space_sm" style_pad_bottom="#space_md" scrollable="false" flex_flow="column"
                style_pad_gap="#space_sm">
          <text_small width="100%"
                      text="Filament diameter sensors for flow compensation"
                      translation_tag="Filament diameter sensors for flow compensation" style_text_align="left"/>
          <lv_obj name="width_sensors_list"
                  width="100%" height="content" style_pad_all="0" scrollable="false" flex_flow="column"
                  style_pad_gap="#space_xs"/>
        </lv_obj>
      </lv_obj>

      <!-- ================================================================== -->
      <!-- HUMIDITY SENSORS SECTION -->
      <!-- ================================================================== -->
      <lv_obj name="humidity_sensors_section"
              width="100%" height="content" style_bg_color="#screen_bg" style_bg_opa="255" style_radius="#border_radius"
              style_pad_all="0" scrollable="false" flex_flow="column" style_pad_gap="0">
        <bind_flag_if_eq subject="humidity_sensor_count" flag="hidden" ref_value="0"/>
        <setting_section_header title="HUMIDITY SENSORS" title_tag="Humidity Sensors" icon="water"
                                badge_name="humidity_sensor_count_label" badge_text="0" hide_badge="false"/>
        <lv_obj width="100%" height="content" style_pad_left="#space_lg" style_pad_right="#space_lg"
                style_pad_top="#space_sm" style_pad_bottom="#space_md" scrollable="false" flex_flow="column"
                style_pad_gap="#space_sm">
          <text_small width="100%"
                      text="Chamber and dryer humidity monitoring"
                      translation_tag="Chamber and dryer humidity monitoring" style_text_align="left"/>
          <lv_obj name="humidity_sensors_list"
                  width="100%" height="content" style_pad_all="0" scrollable="false" flex_flow="column"
                  style_pad_gap="#space_xs"/>
        </lv_obj>
      </lv_obj>

      <!-- ================================================================== -->
      <!-- ACCELEROMETER SENSORS SECTION -->
      <!-- ================================================================== -->
      <lv_obj name="accel_sensors_section"
              width="100%" height="content" style_bg_color="#screen_bg" style_bg_opa="255" style_radius="#border_radius"
              style_pad_all="0" scrollable="false" flex_flow="column" style_pad_gap="0">
        <bind_flag_if_eq subject="accel_count" flag="hidden" ref_value="0"/>
        <setting_section_header title="ACCELEROMETERS" title_tag="Accelerometers" icon="waveform"
                                badge_name="accel_sensor_count_label" badge_text="0" hide_badge="false"/>
        <lv_obj width="100%" height="content" style_pad_left="#space_lg" style_pad_right="#space_lg"
                style_pad_top="#space_sm" style_pad_bottom="#space_md" scrollable="false" flex_flow="column"
                style_pad_gap="#space_sm">
          <text_small width="100%"
                      text="Input shaper calibration sensors"
                      translation_tag="Input shaper calibration sensors" style_text_align="left"/>
          <lv_obj name="accel_sensors_list"
                  width="100%" height="content" style_pad_all="0" scrollable="false" flex_flow="column"
                  style_pad_gap="#space_xs"/>
        </lv_obj>
      </lv_obj>

      <!-- ================================================================== -->
      <!-- COLOR SENSORS SECTION -->
      <!-- ================================================================== -->
      <lv_obj name="color_sensors_section"
              width="100%" height="content" style_bg_color="#screen_bg" style_bg_opa="255" style_radius="#border_radius"
              style_pad_all="0" scrollable="false" flex_flow="column" style_pad_gap="0">
        <bind_flag_if_eq subject="color_sensor_count" flag="hidden" ref_value="0"/>
        <setting_section_header title="COLOR SENSORS" title_tag="Color Sensors" icon="palette"
                                badge_name="color_sensor_count_label" badge_text="0" hide_badge="false"/>
        <lv_obj width="100%" height="content" style_pad_left="#space_lg" style_pad_right="#space_lg"
                style_pad_top="#space_sm" style_pad_bottom="#space_md" scrollable="false" flex_flow="column"
                style_pad_gap="#space_sm">
          <text_small width="100%"
                      text="TD-1 filament color detection"
                      translation_tag="TD-1 filament color detection" style_text_align="left"/>
          <lv_obj name="color_sensors_list"
                  width="100%" height="content" style_pad_all="0" scrollable="false" flex_flow="column"
                  style_pad_gap="#space_xs"/>
        </lv_obj>
      </lv_obj>

      <!-- ================================================================== -->
      <!-- CHAMBER ASSIGNMENT SECTION -->
      <!-- ================================================================== -->
      <lv_obj name="chamber_assignment_card"
              width="100%" height="content"
              style_bg_color="#card_bg" style_bg_opa="255"
              style_radius="#border_radius"
              style_pad_all="#space_md"
              style_border_width="1" style_border_color="#card_border"
              flex_flow="column" style_pad_gap="#space_sm"
              scrollable="false">

        <text_small text="Chamber Assignment"
                    translation_tag="Chamber Assignment"
                    style_text_color="#text"/>

        <text_tiny text="Override auto-detection if your chamber sensor or heater isn't named 'chamber'."
                   translation_tag="Override auto-detection if your chamber sensor or heater isn't named 'chamber'."
                   style_text_color="#text_muted"/>

        <!-- Chamber Heater Row -->
        <lv_obj width="100%" height="content"
                style_pad_all="0" style_bg_opa="0" style_border_width="0"
                flex_flow="row" style_flex_cross_place="center"
                scrollable="false">
          <text_small text="Chamber Heater"
                      translation_tag="Chamber Heater"
                      style_text_color="#text_secondary"
                      style_flex_grow="1"/>
          <lv_dropdown name="chamber_heater_dropdown"
                       options="Auto"
                       style_min_width="200"/>
        </lv_obj>

        <!-- Chamber Sensor Row -->
        <lv_obj width="100%" height="content"
                style_pad_all="0" style_bg_opa="0" style_border_width="0"
                flex_flow="row" style_flex_cross_place="center"
                scrollable="false">
          <text_small text="Chamber Sensor"
                      translation_tag="Chamber Sensor"
                      style_text_color="#text_secondary"
                      style_flex_grow="1"/>
          <lv_dropdown name="chamber_sensor_dropdown"
                       options="Auto"
                       style_min_width="200"/>
        </lv_obj>
      </lv_obj>

      <!-- ================================================================== -->
      <!-- TEMPERATURE SENSORS SECTION -->
      <!-- ================================================================== -->
      <lv_obj name="temp_sensors_section"
              width="100%" height="content" style_bg_color="#screen_bg" style_bg_opa="255" style_radius="#border_radius"
              style_pad_all="0" scrollable="false" flex_flow="column" style_pad_gap="0">
        <bind_flag_if_eq subject="temp_sensor_count" flag="hidden" ref_value="0"/>
        <setting_section_header title="TEMPERATURE SENSORS" title_tag="Temperature Sensors" icon="thermometer"
                                badge_name="temp_sensor_count_label" badge_text="0" hide_badge="false"/>
        <lv_obj width="100%" height="content" style_pad_left="#space_lg" style_pad_right="#space_lg"
                style_pad_top="#space_sm" style_pad_bottom="#space_md" scrollable="false" flex_flow="column"
                style_pad_gap="#space_sm">
          <text_small width="100%"
                      text="MCU, host, and auxiliary temperature monitoring"
                      translation_tag="MCU, host, and auxiliary temperature monitoring" style_text_align="left"/>
          <lv_obj name="temp_sensors_list"
                  width="100%" height="content" style_pad_all="0" scrollable="false" flex_flow="column"
                  style_pad_gap="#space_xs"/>
        </lv_obj>
      </lv_obj>

      <!-- ================================================================== -->
      <!-- NO SENSORS PLACEHOLDER -->
      <!-- ================================================================== -->
      <!-- Placeholder only visible when ALL sensor counts are zero.
           Hidden programmatically by C++ when any sensors exist. -->
      <centered_column name="no_sensors_placeholder" flex_grow="1" style_pad_all="#space_lg" hidden="true">
        <icon src="sensor" size="md" variant="secondary"/>
        <text_small text="No sensors detected" translation_tag="No sensors detected" style_margin_top="#space_sm"/>
      </centered_column>

      <!-- ================================================================== -->
      <!-- INFO NOTE -->
      <!-- ================================================================== -->
      <info_note icon="info"
                 text="Assign a role to enable sensor monitoring"
                 translation_tag="Assign a role to enable sensor monitoring" style_pad_left="#space_sm"
                 style_pad_bottom="#space_md"/>
    </lv_obj>
  </view>
</component>
