<component>
  <api>
    <prop name="macro_name" type="string" default="MACRO"/>
    <prop name="macro_description" type="string" default=""/>
    <prop name="hide_description" type="boolean" default="true"/>
  </api>
  <view name="macro_card"
        extends="lv_button" width="100%" height="content" style_radius="#border_radius" style_bg_color="#card_bg"
        style_bg_opa="255" style_border_width="0" style_pad_all="#space_md" style_shadow_width="0">
    <!-- Content container: icon + text -->
    <lv_obj width="100%"
            height="content" flex_flow="row" style_flex_cross_place="center" style_pad_gap="#space_sm"
            scrollable="false" clickable="false">
      <!-- Code/script icon -->
      <icon name="macro_icon" src="code_tags" size="sm" variant="primary"/>
      <!-- Text container: name + optional description -->
      <lv_obj flex_grow="1" flex_flow="column" style_pad_gap="#space_xs" scrollable="false" clickable="false">
        <text_body name="macro_label" text="$macro_name"/>
        <text_small name="macro_desc" text="$macro_description" hidden="$hide_description"
                    style_text_color="#text_muted" long_mode="clip" width="100%"/>
      </lv_obj>
      <!-- Chevron indicating it's tappable -->
      <icon name="chevron_icon" src="chevron_right" size="sm" variant="secondary"/>
    </lv_obj>
    <!-- Event callback for macro execution -->
    <event_cb trigger="clicked" callback="on_macro_card_clicked"/>
  </view>
</component>
