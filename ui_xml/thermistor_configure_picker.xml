<component>
  <!-- Full-screen backdrop overlay - tap to dismiss -->
  <view name="thermistor_configure_picker" extends="lv_obj"
        width="100%" height="100%" style_bg_opa="128" style_bg_color="0x000000"
        style_border_width="0" style_pad_all="0" style_radius="0" clickable="true">
    <event_cb trigger="clicked" callback="thermistor_picker_backdrop_cb"/>
    <!-- Context menu card - positioned by C++ -->
    <lv_obj name="context_menu"
            width="content" height="content" style_max_height="85%"
            style_bg_color="#elevated_bg" style_bg_opa="255"
            style_radius="#border_radius" style_pad_all="#space_sm" style_pad_gap="#space_sm"
            flex_flow="column" style_flex_main_place="start" style_flex_cross_place="start"
            scrollable="true" clickable="true">
      <!-- Header row: title + Done button -->
      <lv_obj width="100%" height="content"
              flex_flow="row" style_flex_main_place="space_between" style_flex_cross_place="center"
              style_pad_all="0"
              scrollable="false" clickable="false" event_bubble="true">
        <text_small text="Select Sensors" translation_tag="Select Sensors"
                    clickable="false" event_bubble="true"/>
        <ui_button name="btn_done" variant="ghost" width="content" height="content"
                   text="Done" translation_tag="Done" icon="check">
          <event_cb trigger="clicked" callback="thermistor_picker_done_cb"/>
        </ui_button>
      </lv_obj>
      <lv_obj width="100%" height="1" style_bg_color="#text_muted" style_bg_opa="38"
              style_pad_all="0" scrollable="false"
              clickable="false" event_bubble="true"/>
      <!-- Sensor rows populated dynamically by C++ -->
      <lv_obj name="sensor_list" width="100%" height="content"
              flex_flow="column" style_pad_all="#space_xs" style_pad_gap="0"
              scrollable="true"/>
    </lv_obj>
  </view>
</component>
